def die(msg: str, code: int = 1) -> None:
    print(f"bridget: {msg}", file=sys.stderr)
    sys.exit(code)


def warn_if_world_readable(path: Path) -> bool:
    """Warn when the env file (which holds the bot token) is readable by anyone
    but its owner. A warning, not an error: a container or a CI runner may
    legitimately have a different ownership model, and refusing to start would
    be worse than saying so. Returns True if the permissions are loose."""
    try:
        mode = path.stat().st_mode & 0o777
    except OSError:
        return False
    if mode & 0o077:
        print(
            f"bridget: WARNING: {path} is readable beyond its owner "
            f"(mode {oct(mode)}). It holds your bot token.\n"
            f"  fix with: chmod 600 {path}",
            file=sys.stderr,
        )
        return True
    return False


def load_env_file(path: Path) -> dict:
    """Parse a `key=value` env file.

    Never logs a value: this file holds DISCORD_BOT_TOKEN, and bridget's whole
    secret-handling contract is that the token is read into memory and handed to
    discord.py, never echoed, printed, or written anywhere else.
    """
    out = {}
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        k, v = line.split('=', 1)
        out[k.strip()] = v.strip()
    return out


def load_config() -> dict:
    if not ENV_FILE.exists():
        die(
            f"config file not found: {ENV_FILE}\n"
            f"  copy bridget.env.example to {ENV_FILE} and fill in your\n"
            f"  Discord bot token + user/server IDs.\n"
            f"  see {INSTALL_DOCS_URL} for setup instructions."
        )

    warn_if_world_readable(ENV_FILE)
    file_env = load_env_file(ENV_FILE)

    def lookup(key: str) -> str | None:
        # Process env wins over the env file so launchd / systemd overrides work.
        return os.environ.get(key) or file_env.get(key)

    missing = [k for k in ('DISCORD_BOT_TOKEN', 'DISCORD_USER_ID', 'DISCORD_SERVER_ID')
               if not lookup(k)]
    if missing:
        die(
            f"missing required key(s) in {ENV_FILE}: {', '.join(missing)}\n"
            f"  see bridget.env.example for the full template."
        )

    try:
        user_id = int(lookup('DISCORD_USER_ID'))
        server_id = int(lookup('DISCORD_SERVER_ID'))
    except ValueError:
        die("DISCORD_USER_ID and DISCORD_SERVER_ID must be integers (Discord snowflake IDs).")

    mg_bin = lookup('MG_BIN') or shutil.which('mg')
    if not mg_bin:
        die(
            "could not find the `mg` binary on PATH.\n"
            "  install pogo and ensure `mg` is reachable, or set MG_BIN in\n"
            f"  {ENV_FILE} to its absolute path.\n"
            f"  see {INSTALL_DOCS_URL} for setup instructions."
        )
    if not Path(mg_bin).exists():
        die(f"MG_BIN points to a missing file: {mg_bin}")

    pogo_bin = lookup('POGO_BIN') or shutil.which('pogo')

    mail_parent_str = lookup('POGO_MAIL_DIR')
    mail_parent = Path(mail_parent_str).expanduser() if mail_parent_str \
        else HOME / '.macguffin' / 'mail' / 'human'

    designs_str = lookup('POGO_DESIGNS_DIR')
    designs_dir = Path(designs_str).expanduser() if designs_str \
        else HOME / '.pogo' / 'designs'

    inbox_str = lookup('POGO_INBOX_REPO')
    inbox_repo = str(Path(inbox_str).expanduser()) if inbox_str \
        else str(HOME / '.pogo' / 'inbox')

    mail_recipient = lookup('POGO_MAIL_RECIPIENT') or 'mayor'
    workflow_agent = lookup('POGO_WORKFLOW_AGENT') or 'architect'
    inbox_tag = lookup('POGO_INBOX_TAG') or 'pogo-inbox'

    poll_interval_str = lookup('BRIDGET_POLL_INTERVAL')
    try:
        poll_interval = int(poll_interval_str) if poll_interval_str else 5
    except ValueError:
        die(f"BRIDGET_POLL_INTERVAL must be an integer (got {poll_interval_str!r}).")
    if poll_interval <= 0:
        die(f"BRIDGET_POLL_INTERVAL must be positive (got {poll_interval}).")

    quiet_respects_outbound_raw = (lookup('BRIDGET_QUIET_RESPECTS_OUTBOUND') or 'false').strip().lower()
    quiet_respects_outbound = quiet_respects_outbound_raw in ('true', '1', 'yes', 'on')

    approval_re_str = lookup('BRIDGET_APPROVAL_RE') or r'^Subject: approval needed '
    try:
        approval_re = re.compile(approval_re_str)
    except re.error as e:
        die(f"BRIDGET_APPROVAL_RE is not a valid regex: {e}")

    restart_cmd_str = lookup('BRIDGET_RESTART_CMD') or 'bash build.sh'
    try:
        restart_cmd = shlex.split(restart_cmd_str)
    except ValueError as e:
        die(f"BRIDGET_RESTART_CMD failed to parse as a shell command: {e}")
    if not restart_cmd:
        die("BRIDGET_RESTART_CMD must not be empty.")

    crew_pattern_str = lookup('BRIDGET_CREW_PATTERN') or r'^(architect|mayor|human|pm-.*|)$'
    try:
        crew_pattern = re.compile(crew_pattern_str)
    except re.error as e:
        die(f"BRIDGET_CREW_PATTERN is not a valid regex: {e}")

    # Threading. Discord threads only exist inside guild text channels — a DM
    # channel cannot host one. So conversation threads are rooted in a "log"
    # channel, and the DM stays the curated inbox. Unset → threading off and
    # behavior is identical to v1.x.
    log_channel_str = lookup('BRIDGET_LOG_CHANNEL_ID')
    log_channel_id = None
    if log_channel_str:
        try:
            log_channel_id = int(log_channel_str)
        except ValueError:
            die("BRIDGET_LOG_CHANNEL_ID must be an integer (a Discord channel snowflake).")

    correlation_ids = (lookup('BRIDGET_CORRELATION_IDS') or 'auto').strip().lower()
    if correlation_ids not in CORRELATION_MODES:
        die(f"BRIDGET_CORRELATION_IDS must be one of {', '.join(CORRELATION_MODES)} "
            f"(got {correlation_ids!r}).")

    dm_policy = (lookup('BRIDGET_DM_POLICY') or DEFAULT_DM_POLICY).strip().lower()
    if dm_policy not in DM_POLICIES:
        die(f"BRIDGET_DM_POLICY must be one of {', '.join(DM_POLICIES)} (got {dm_policy!r}).")
    if dm_policy != 'all' and log_channel_id is None:
        # Without a log channel there is no second surface, so a policy that
        # suppresses DMs would silently drop mail. Refuse rather than swallow.
        die(
            f"BRIDGET_DM_POLICY={dm_policy} needs BRIDGET_LOG_CHANNEL_ID set — otherwise\n"
            f"  mail suppressed from your DMs would have nowhere else to go.\n"
            f"  see bridget.env.example for the threading setup."
        )

    return {
        'token': lookup('DISCORD_BOT_TOKEN'),
        'user_id': user_id,
        'server_id': server_id,
        'mg_bin': mg_bin,
        'pogo_bin': pogo_bin,
        'mail_parent': mail_parent,
        'mail_dir': mail_parent / 'new',
        'designs_dir': designs_dir,
        'inbox_repo': inbox_repo,
        'mail_recipient': mail_recipient,
        'workflow_agent': workflow_agent,
        'inbox_tag': inbox_tag,
        'poll_interval': poll_interval,
        'quiet_respects_outbound': quiet_respects_outbound,
        'approval_re': approval_re,
        'restart_cmd': restart_cmd,
        'crew_pattern': crew_pattern,
        'log_channel_id': log_channel_id,
        'dm_policy': dm_policy,
        'correlation_ids': correlation_ids,
    }


VALID_DIRECTIONS = frozenset({'inbound', 'outbound', 'both'})
VALID_KINDS = frozenset({'mail', 'task-transitions', 'idea-claims'})


def load_channels(path: Path = CHANNELS_FILE) -> tuple[dict, dict, dict]:
    """Read ~/.pogo/bridget.channels.toml. Returns (by_name, by_snowflake,
    outbound_by_agent) where:

    - by_name        {channel_name: entry}             — every well-formed entry
    - by_snowflake   {snowflake_int: entry}            — only direction in {inbound, both}
    - outbound_by_agent {agent_name: [entry, ...]}     — only direction in {outbound, both}

    Each entry is a dict {name, snowflake, agent, direction, kinds}. `kinds` is a
    frozenset over VALID_KINDS controlling which outbound classes fan out to that
    channel; defaults to all kinds.

    Missing file → three empty dicts (P1 mode). Malformed entries are logged and
    skipped; we never raise so a single typo can't take bridget down."""
    if not path.exists():
        return {}, {}, {}
    if tomllib is None:
        print(
            f'bridget.channels.toml present but tomllib unavailable '
            f'(needs Python 3.11+); per-channel routing disabled.',
            file=sys.stderr,
        )
        return {}, {}, {}
    try:
        data = tomllib.loads(path.read_text())
    except (tomllib.TOMLDecodeError, OSError) as e:
        print(f'bridget.channels.toml parse error: {e}', file=sys.stderr)
        return {}, {}, {}

    raw = data.get('channels')
    if raw is None:
        return {}, {}, {}
    if not isinstance(raw, dict):
        print('bridget.channels.toml: [channels] must be a table', file=sys.stderr)
        return {}, {}, {}

    by_name: dict = {}
    by_snowflake: dict = {}
    outbound_by_agent: dict = {}
    for name, entry in raw.items():
        if not isinstance(entry, dict):
            print(
                f'bridget.channels.toml: skipping [channels.{name}]: not a table',
                file=sys.stderr,
            )
            continue
        try:
            snowflake_raw = entry.get('snowflake')
            if snowflake_raw is None:
                raise ValueError('missing snowflake')
            snowflake = int(str(snowflake_raw).strip())
            agent = str(entry.get('agent', '')).strip()
            if not agent:
                raise ValueError('missing or empty agent')
            direction = str(entry.get('direction', 'both')).strip().lower()
            if direction not in VALID_DIRECTIONS:
                raise ValueError(
                    f'invalid direction {direction!r} (expected one of '
                    f'{sorted(VALID_DIRECTIONS)})'
                )
            kinds_raw = entry.get('kinds')
            if kinds_raw is None:
                kinds = frozenset(VALID_KINDS)
            elif not isinstance(kinds_raw, list):
                raise ValueError('kinds must be a list of strings')
            else:
                kinds_set = {str(k).strip().lower() for k in kinds_raw}
                bad = kinds_set - VALID_KINDS
                if bad:
                    raise ValueError(
                        f'invalid kinds {sorted(bad)} (expected subset of '
                        f'{sorted(VALID_KINDS)})'
                    )
                kinds = frozenset(kinds_set)
        except (ValueError, TypeError) as e:
            print(
                f'bridget.channels.toml: skipping [channels.{name}]: {e}',
                file=sys.stderr,
            )
            continue

        ch = {
            'name': name,
            'snowflake': snowflake,
            'agent': agent,
            'direction': direction,
            'kinds': kinds,
        }
        by_name[name] = ch
        if direction in ('inbound', 'both'):
            existing = by_snowflake.get(snowflake)
            if existing is not None:
                # Two inbound entries pointing at the same Discord channel would
                # silently collide on routing; reject the later one and keep the
                # first so config order determines precedence.
                print(
                    f'bridget.channels.toml: duplicate inbound snowflake '
                    f'{snowflake} on [channels.{name}] (already used by '
                    f'[channels.{existing["name"]}]); dropping',
                    file=sys.stderr,
                )
            else:
                by_snowflake[snowflake] = ch
        if direction in ('outbound', 'both'):
            outbound_by_agent.setdefault(agent, []).append(ch)

    return by_name, by_snowflake, outbound_by_agent


