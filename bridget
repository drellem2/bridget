QUIET_DEFAULTS = {'enabled': False, 'start': '23:00', 'end': '06:00'}
TIME_RE = re.compile(r'^[0-2]\d:[0-5]\d$')


def load_quiet() -> dict:
    """Read ~/.pogo/quiet.json. Missing/unreadable file → defaults."""
    if not QUIET_FILE.exists():
        return {**QUIET_DEFAULTS, 'updated_at': ''}
    try:
        d = json.loads(QUIET_FILE.read_text())
    except Exception as e:
        print(f'load_quiet parse error: {e}', file=sys.stderr)
        return {**QUIET_DEFAULTS, 'updated_at': ''}
    return {
        'enabled': bool(d.get('enabled', False)),
        'start': d.get('start') or QUIET_DEFAULTS['start'],
        'end': d.get('end') or QUIET_DEFAULTS['end'],
        'updated_at': d.get('updated_at', ''),
    }


def save_quiet(state: dict) -> None:
    """Atomically write ~/.pogo/quiet.json with all schema keys populated."""
    out = {
        'enabled': bool(state.get('enabled', False)),
        'start': state.get('start') or QUIET_DEFAULTS['start'],
        'end': state.get('end') or QUIET_DEFAULTS['end'],
        'updated_at': datetime.datetime.now().astimezone().isoformat(timespec='seconds'),
    }
    write_state(QUIET_FILE, json.dumps(out, indent=2) + '\n')


def is_quiet_now() -> bool:
    """True iff quiet hours are enabled AND we are currently inside the
    configured local-time window. Windows that wrap midnight (start > end) are
    handled. Used to gate outbound DMs when BRIDGET_QUIET_RESPECTS_OUTBOUND=true."""
    state = load_quiet()
    if not state.get('enabled'):
        return False
    if not (TIME_RE.match(state.get('start', '')) and TIME_RE.match(state.get('end', ''))):
        return False
    sh, sm = (int(x) for x in state['start'].split(':'))
    eh, em = (int(x) for x in state['end'].split(':'))
    s, e = sh * 60 + sm, eh * 60 + em
    if s == e:
        return False
    now = datetime.datetime.now()
    cur = now.hour * 60 + now.minute
    if s < e:
        return s <= cur < e
    return cur >= s or cur < e


def load_task_states() -> tuple[dict, bool]:
    """Read the task-state cache. Returns (states, file_existed). Missing or
    malformed → empty dict + False so callers can prime silently."""
    if not TASK_STATES_FILE.exists():
        return {}, False
    try:
        d = json.loads(TASK_STATES_FILE.read_text())
        if not isinstance(d, dict):
            raise ValueError('not a dict')
        return {k: str(v) for k, v in d.items()}, True
    except Exception as e:
        print(f'load_task_states parse error: {e}', file=sys.stderr)
        return {}, True


def save_task_states(states: dict) -> None:
    """Atomically write the task-state cache."""
    write_state(TASK_STATES_FILE, json.dumps(states, indent=2, sort_keys=True) + '\n')


def load_idea_claims() -> tuple[set, bool]:
    """Read the idea-claims cache. Returns (claimed_ids, file_existed).
    Missing or malformed → empty set + False so callers can prime silently."""
    if not IDEA_CLAIMS_FILE.exists():
        return set(), False
    try:
        d = json.loads(IDEA_CLAIMS_FILE.read_text())
        if isinstance(d, dict):
            ids = d.get('claimed_ids', [])
        elif isinstance(d, list):
            ids = d
        else:
            raise ValueError('not a dict or list')
        return {str(x) for x in ids}, True
    except Exception as e:
        print(f'load_idea_claims parse error: {e}', file=sys.stderr)
        return set(), True


def save_idea_claims(ids: set) -> None:
    """Atomically write the idea-claims cache."""
    payload = {'claimed_ids': sorted(ids)}
    write_state(IDEA_CLAIMS_FILE, json.dumps(payload, indent=2) + '\n')


_TRANSITION_FORMATS = {
    'claimed': '🚀 claimed {id}{by}: {title}',
    'done': '✅ done {id}: {title}',
    'shelved': '📦 shelved {id}: {title}',
}


def format_transition(task: dict, new_status: str):
    fmt = _TRANSITION_FORMATS.get(new_status)
    if fmt is None:
        return None
    title = (task.get('title') or '?')[:80]
    by = ''
    if new_status == 'claimed':
        assignee = (task.get('assignee') or '').strip()
        if assignee and not CREW_PATTERN.match(assignee.lower()):
            by = f' by {assignee}'
    return fmt.format(id=task.get('id', '?'), by=by, title=title)


def humanize_ago(seconds: float) -> str:
    """Compact 'time ago' formatter."""
    s = int(seconds)
    if s < 60:
        return 'just now'
    if s < 3600:
        return f'{s // 60}m ago'
    if s < 86400:
        return f'{s // 3600}h ago'
    return f'{s // 86400}d ago'


def _humanize_seconds(seconds: float) -> str:
    s = int(seconds)
    if s < 60:
        return f'{s}s'
    if s < 3600:
        m, sec = divmod(s, 60)
        return f'{m}m{sec:02d}s'
    h, rem = divmod(s, 3600)
    return f'{h}h{rem // 60}m'


def _parse_iso_utc(ts: str) -> datetime.datetime:
    if ts.endswith('Z'):
        ts = ts[:-1] + '+00:00'
    return datetime.datetime.fromisoformat(ts).astimezone(datetime.timezone.utc)


def agent_cycle_paren(name: str) -> str:
    """Return '(last cycle X ago, next cycle in Y)' read from
    ~/.pogo/agent-status/<name>.json, or '(last cycle ?, next cycle ?)' if the
    file is missing, malformed, or its updated_at is older than 30 minutes."""
    try:
        data = json.loads((AGENT_STATUS_DIR / f'{name}.json').read_text())
        last = _parse_iso_utc(data['last_cycle'])
        nxt = _parse_iso_utc(data['next_cycle'])
        updated = _parse_iso_utc(data['updated_at'])
        now = datetime.datetime.now(datetime.timezone.utc)
        if now - updated > AGENT_STATUS_STALE:
            return '(last cycle ?, next cycle ?)'
        last_ago = _humanize_seconds(max(0, (now - last).total_seconds()))
        delta = (nxt - now).total_seconds()
        if delta < 0:
            return f'(last cycle {last_ago} ago, next cycle overdue {_humanize_seconds(-delta)})'
        return f'(last cycle {last_ago} ago, next cycle in {_humanize_seconds(delta)})'
    except Exception:
        return '(last cycle ?, next cycle ?)'


MAIL_BODY_PREVIEW = 1200

#: Ceiling on the "📬 **sender** — subject" line of a card. The sender and the
#: subject are both text an agent chose; without a bound a long one leaves no
#: room for the body.
MAIL_HEADER_LIMIT = 400

#: Discord opens a code block on a run of three or more backticks. Everything we
#: put inside a fence is text somebody else wrote — a mail body, mg's stdout —
#: and agents post code constantly, so a body carrying its own fence is the
#: common case, not the adversarial one. Left alone it closes our block early
#: and the remainder renders as raw markdown.
BACKTICK_RUN_RE = re.compile('`{3,}')
ZERO_WIDTH_SPACE = '​'

#: The overhead `code_block` adds around the body: the two fences and the two
#: newlines that must hug them for Discord to recognize the block.
_FENCE_OVERHEAD = len('```\n\n```')


def defuse_fences(text: str) -> str:
    """Break every run of three-or-more backticks so it cannot close a fence.

    A zero-width space between the backticks is invisible in Discord and leaves
    the run readable as the backticks it was.
    """
    return BACKTICK_RUN_RE.sub(
        lambda m: ZERO_WIDTH_SPACE.join('`' * len(m.group(0))), text)


def code_block(body: str, budget: int | None = None) -> str:
    """Render `body` as a fenced block that is always closed.

    Truncation happens *inside* the fence. Chopping the rendered string — which
    is what a naive `msg[:limit]` does — is how you lose the closing fence and
    let the tail of a long mail render as markdown.
    """
    body = defuse_fences(body)
    if budget is not None:
        room = budget - _FENCE_OVERHEAD
        if room < 1:
            # No room for a block at all; the caller's header ate the budget.
            return ''
        if len(body) > room:
            body = body[:room - 1] + '…'
    return f'```\n{body}\n```'


# -- rendering the core's outcome types -------------------------------------
#
# `bridget_core` hands us facts: an Ack's `kind` and the fields behind it, a
# settings `summary()` dict. Everything below turns those into Discord — emoji,
# `**bold**`, backticks, and the character budgets Discord imposes. It is the
# only place that knows what a message looks like, which is what makes "port to
# Slack" a new adapter rather than a rewrite.

#: How much of a subject an ack echoes back before eliding it.
ACK_SUBJECT_LIMIT = 60

#: How much of mg's rejection we quote. Long enough to be actionable.
ACK_REASON_LIMIT = 300

#: Ambiguity candidates listed before "… and N more".
ACK_CANDIDATE_LIMIT = 5

#: Muted conversations listed by the `settings` command before eliding.
SETTINGS_MUTED_LIMIT = 10


def _elide(text: str, limit: int) -> str:
    return text if len(text) <= limit else text[:limit - 1] + '…'


def render_ack(ack: acks.Ack) -> str:
    """Turn a delivery outcome into the line the human reads."""
    if ack.kind == acks.DELIVERED:
        text = f'✅ delivered to `{ack.agent}`'
        if ack.subject:
            text += f' — "{_elide(ack.subject, ACK_SUBJECT_LIMIT)}"'
        if ack.in_reply_to:
            # Surfacing the threading tells the human their reply will land *in*
            # the conversation, not as a fresh top-level mail.
            text += '\n↳ threaded as a reply'
        return text

    if ack.kind == acks.AMBIGUOUS:
        n = len(ack.candidates)
        if n == 0:
            text = (
                "⚠️ I can't tell which conversation this replies to.\n"
                'Reply inside a conversation thread, or use `mail <subject>` to '
                'start a new one.'
            )
        else:
            text = f'⚠️ ambiguous — this could reply to **{n}** conversations:\n'
            text += '\n'.join(f'• {label}'
                              for label, _ in ack.candidates[:ACK_CANDIDATE_LIMIT])
            if n > ACK_CANDIDATE_LIMIT:
                text += f'\n… and {n - ACK_CANDIDATE_LIMIT} more'
            text += '\nReply inside the thread you mean.'
        if ack.hint:
            text += f'\n{ack.hint}'
        return text

    where = f' to `{ack.agent}`' if ack.agent else ''
    reason = _elide(ack.reason, ACK_REASON_LIMIT) or 'unknown error'
    return f'❌ undeliverable{where}: {reason}'


def render_settings(summary: dict) -> str:
    """Turn `SettingsStore.summary()` into the `settings` command's output."""
    lines = [
        '⚙️ **bridget settings**',
        f"• DM policy: `{summary['dm_policy']}`",
        f"• Mute all DMs: `{str(summary['mute_all']).lower()}`",
    ]
    muted = summary['muted']
    if muted:
        lines.append(f'• Muted conversations: **{len(muted)}**')
        lines.extend(f'    – {label}' for _, label in muted[:SETTINGS_MUTED_LIMIT])
        if len(muted) > SETTINGS_MUTED_LIMIT:
            lines.append(f'    … and {len(muted) - SETTINGS_MUTED_LIMIT} more')
    else:
        lines.append('• Muted conversations: none')
    if summary['updated_at']:
        lines.append(f"• Updated: {summary['updated_at']}")
    return '\n'.join(lines)


def format_mail_card(mail: dict, thread_link: str = '', prefix: str = '',
                     hint: str = '; use `read <mg-id>`') -> str:
    """The card for one mail. Compact by design — the DM is a to-do list, not a
    reading surface; the thread (or `read <mg-id>`) holds the full text."""
    body_preview = mail['body']
    if len(body_preview) > MAIL_BODY_PREVIEW:
        body_preview = body_preview[:MAIL_BODY_PREVIEW] + f'\n…[truncated{hint}]'
    header = f"{prefix}📬 **{mail['from']}** — {mail['subject']}\n"
    footer = f"\n💬 reply in thread: {thread_link}" if thread_link else ''
    # A subject is attacker-adjacent text too: bound the header so it can never
    # squeeze the body's fence out of the message entirely.
    if len(header) > MAIL_HEADER_LIMIT:
        header = header[:MAIL_HEADER_LIMIT - 2] + '…\n'
    block = code_block(body_preview, budget=DISCORD_MSG_LIMIT - len(header) - len(footer))
    return header + block + footer


def wants_attention(mail: dict) -> bool:
    """True if this mail asks the human for a decision, and so earns a DM even
    under the `curated` policy. Today that means an approval request, matched
    with the same BRIDGET_APPROVAL_RE the `status` view uses."""
    return bool(APPROVAL_RE.match(f"Subject: {mail['subject']}"))


def should_dm(mail: dict, conversation: str) -> bool:
    """Decide whether this mail interrupts the human.

    Three gates, in order of authority:
      quiet hours   — an explicit do-not-disturb window
      mute          — the human silenced this conversation (or all of them)
      DM policy     — how much of the firehose reaches the DM at all
    """
    if QUIET_RESPECTS_OUTBOUND and is_quiet_now():
        return False
    if SETTINGS.is_muted(conversation):
        return False
    if SETTINGS.dm_policy == 'none':
        return False
    if SETTINGS.dm_policy == 'curated':
        return wants_attention(mail)
    return True


def dm_globally_suppressed() -> bool:
    """True if *no* mail can currently reach the DM, whatever its conversation.

    Distinct from `should_dm`, which is per-mail. When threading is off the DM is
    the only push surface, so a globally-suppressed DM means a polled mail would
    be consumed by the seen-set and pushed nowhere. The watcher uses this to
    stop polling instead — deferring the mail rather than swallowing it.
    """
    if QUIET_RESPECTS_OUTBOUND and is_quiet_now():
        return True
    return SETTINGS.mute_all or SETTINGS.dm_policy == 'none'


def thread_url(thread_id) -> str:
    return f'https://discord.com/channels/{SERVER_ID}/{thread_id}'


async def resolve_thread(conv, mail: dict):
    """Return the Discord thread rendering `conv`, creating it if needed.

    A conversation's first mail posts a root card in the log channel and opens a
    thread off it; later mail in the same chain posts into that thread. The
    thread id is persisted, so a restart re-attaches to the existing thread
    rather than rooting a duplicate.

    Returns None if the log channel is unusable — the caller falls back to a DM
    rather than dropping the mail.
    """
    if conv.thread_id is not None:
        thread = client.get_channel(conv.thread_id)
        if thread is None:
            try:
                thread = await client.fetch_channel(conv.thread_id)
            except (discord.NotFound, discord.Forbidden):
                # The human deleted the thread. Drop the binding and re-root.
                thread = None
            except discord.HTTPException as e:
                print(f'thread fetch failed ({conv.thread_id}): {e}', file=sys.stderr)
                return None
        if thread is not None:
            if getattr(thread, 'archived', False):
                # Discord refuses sends to an archived thread; reopen it.
                try:
                    await thread.edit(archived=False)
                except discord.HTTPException as e:
                    print(f'thread unarchive failed ({conv.thread_id}): {e}', file=sys.stderr)
                    return None
            return thread

    channel = client.get_channel(LOG_CHANNEL_ID)
    if channel is None:
        try:
            channel = await client.fetch_channel(LOG_CHANNEL_ID)
        except discord.HTTPException as e:
            print(f'log channel {LOG_CHANNEL_ID} unusable: {e}', file=sys.stderr)
            return None
    if not hasattr(channel, 'create_thread'):
        print(
            f'log channel {LOG_CHANNEL_ID} cannot host threads — '
            f'BRIDGET_LOG_CHANNEL_ID must name a guild text channel, not a '
            f'DM, category, or voice channel.',
            file=sys.stderr,
        )
        return None

    try:
        root = await channel.send(f"📬 **{mail['from']}** — {mail['subject']}")
        thread = await root.create_thread(
            name=conv.subject[:DISCORD_THREAD_NAME_LIMIT] or 'conversation')
    except discord.HTTPException as e:
        print(f'thread create failed for {conv.key}: {e}', file=sys.stderr)
        return None

    CONVERSATIONS.bind_thread(conv.key, thread.id)
    return thread


async def post_to_thread(conv, mail: dict) -> str:
    """Post `mail` into its conversation thread. Returns the thread URL, or ''
    if the thread could not be reached."""
    thread = await resolve_thread(conv, mail)
    if thread is None:
        return ''
    body = mail['body'] or '(no body)'
    header = f"**{mail['from']}** — {mail['subject']}\n"
    if len(header) > MAIL_HEADER_LIMIT:
        header = header[:MAIL_HEADER_LIMIT - 2] + '…\n'
    text = header + code_block(body, budget=DISCORD_MSG_LIMIT - len(header))
    try:
        await thread.send(text)
    except discord.HTTPException as e:
        print(f'thread send failed ({thread.id}): {e}', file=sys.stderr)
        return ''
    return thread_url(thread.id)


async def deliver_mail(user: discord.User, filename: str, mail: dict) -> bool:
    """Route one new mail to the surfaces it belongs on.

    Threading (when enabled) always happens: the log channel is the durable
    record, and muting a conversation should not make its mail disappear. Only
    the DM is gated.

    The exception is a log channel we could not reach. If we then also honored a
    `curated`/`none` policy or a mute, the mail would surface nowhere. In that
    one case the DM is the last surface standing, and it wins over policy, mute,
    and quiet hours — a mail arriving at a bad hour is a smaller harm than a mail
    nobody ever sees.

    Returns False if a *send* failed, so the caller leaves the mail uncommitted
    and retries it on the next poll. A mail deliberately suppressed by policy
    returns True: it was handled, not dropped.

    Delivery is at-least-once (see `MaildirWatcher.poll`), so this function must
    be idempotent per mail. Posting to the thread is guarded on `was_posted`;
    the DM is not, because a duplicate DM is the acceptable half of the trade and
    Discord gives us no idempotency key to dedupe on.
    """
    # Join the conversation any of this message's ancestors already belongs to;
    # only mint a fresh key when we recognize none of them. Probing first is
    # what carries a thread past its first round-trip — a reply's `References`
    # names its parent, not the root the conversation is keyed on.
    key = (CONVERSATIONS.resolve(correlation_candidates(mail, fallback=filename))
           or conversation_key(mail, fallback=filename))

    if THREADS_ENABLED:
        message_id = reply_target(mail, fallback=filename)
        conv = CONVERSATIONS.record(
            key,
            subject=thread_title(mail, limit=THREAD_TITLE_LIMIT),
            agent=mail['from'],
            message_id=message_id,
        )
        if CONVERSATIONS.was_posted(key, message_id):
            # A redelivery: the DM failed last time, or we died between the
            # thread send and the commit. The thread already holds this mail —
            # posting it again is the one duplicate we can actually prevent.
            url = thread_url(conv.thread_id) if conv.thread_id is not None else ''
        else:
            url = await post_to_thread(conv, mail)
            if url:
                CONVERSATIONS.mark_posted(key, message_id)
    else:
        # No threads, no thread map. Recording every mail here would rewrite the
        # conversation file on each delivery for a feature that is switched off.
        url = ''

    stranded = THREADS_ENABLED and not url
    if not stranded and not should_dm(mail, key):
        return True

    prefix = ''
    if stranded:
        prefix = '⚠️ log channel unreachable — delivering here instead.\n'
    try:
        await user.send(format_mail_card(mail, thread_link=url, prefix=prefix))
    except discord.HTTPException as e:
        # Transient by default (429/5xx). Report failure so the mail is retried
        # rather than silently consumed by the seen-set.
        print(f'DM failed for {filename}, will retry: {e}', file=sys.stderr)
        return False
    return True


async def send_startup_dm(user: discord.User, first_run: bool) -> None:
    if QUIET_RESPECTS_OUTBOUND and is_quiet_now():
        return
    if SETTINGS.mute_all:
        return
    try:
        if first_run:
            await user.send(
                "🔔 bridget online. I'll DM you when new mail arrives in "
                "`human/new/`. Recognized replies:\n" + COMMAND_LIST
            )
            return
        summary = get_status_summary()
        if len(summary) > STATUS_OUTPUT_BUDGET:
            summary = summary[:STATUS_OUTPUT_BUDGET] + '\n…(truncated)'
        await user.send(
            f"🔔 bridget online.\n\n{summary}\n\n"
            f"Send `help` for a list of commands."
        )
    except discord.HTTPException as e:
        print(f"startup DM failed: {e}", file=sys.stderr)


async def watch_mailbox(user: discord.User):
    """Poll the human's maildir and deliver new mail. Observe-only: the watcher
    reads `new/` and never moves anything out of it — `mg mail read` owns that,
    and the `dismiss`/`read` commands are the only things here that mark mail
    read, because the human asked them to."""
    watcher = MaildirWatcher(MAIL_DIR, SEEN_FILE)
    first_run = not watcher.primed
    if first_run:
        # Adopt the backlog rather than replaying it into chat.
        watcher.prime()
    await send_startup_dm(user, first_run)

    while not client.is_closed():
        try:
            SETTINGS.reload_if_changed()
            # With no log channel the DM is the only surface. Rather than poll
            # mail we cannot push anywhere — which would mark it seen and lose
            # it — leave it in the maildir and pick it up once we're audible.
            if THREADS_ENABLED or not dm_globally_suppressed():
                for filename, mail in watcher.poll():
                    # Isolate each mail: one bad message must not abort the loop
                    # and strand every mail queued behind it. A mail is only
                    # committed — marked seen on disk — once it has landed.
                    try:
                        if await deliver_mail(user, filename, mail):
                            watcher.commit(filename)
                    except Exception as e:
                        print(f"deliver failed for {filename}, will retry: {e}",
                              file=sys.stderr)
        except Exception as e:
            print(f"watch_mailbox loop error: {e}", file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


def agent_mail_dir(agent: str) -> Path:
    """Return ~/.macguffin/mail/<agent>/new/ derived from MAIL_ROOT so
    POGO_MAIL_DIR overrides keep their parent layout."""
    return MAIL_ROOT / agent / 'new'


def agent_seen_file(agent: str) -> Path:
    """Per-agent seen-state file. Separate from `bridget.seen` so the human
    DM watcher and the channel watchers don't fight over each other's state."""
    safe = re.sub(r'[^A-Za-z0-9_.-]', '_', agent)
    return HOME / '.pogo' / f'bridget.seen.{safe}'


def format_agent_mail_msg(mail: dict) -> str:
    """Same card as the human DM, minus the `read <mg-id>` hint — that command
    only makes sense in the human's own DM."""
    return format_mail_card(mail, hint='')


async def watch_agent_mailbox(channel_entry: dict):
    """Outbound fan-out for an agent's mailbox into a Discord channel.

    Polls ~/.macguffin/mail/<agent>/new/ for new mails and posts each one to
    the mapped Discord text channel. Independent seen-state per agent so this
    doesn't intersect the human-DM watcher's `bridget.seen` file.

    Skipped silently if `kinds` doesn't include 'mail' for this entry."""
    if 'mail' not in channel_entry['kinds']:
        return
    agent = channel_entry['agent']
    snowflake = channel_entry['snowflake']

    watcher = MaildirWatcher(agent_mail_dir(agent), agent_seen_file(agent))
    if not watcher.primed:
        # Adopt the backlog on first run so we don't flood the channel.
        watcher.prime()

    while not client.is_closed():
        try:
            channel = client.get_channel(snowflake)
            if channel is None:
                # The bot may not have joined the guild yet, or the channel
                # snowflake is wrong. Don't churn — just wait and retry, and
                # crucially don't poll: a mail consumed now would be marked
                # seen and never reach the channel.
                await asyncio.sleep(POLL_INTERVAL)
                continue
            if QUIET_RESPECTS_OUTBOUND and is_quiet_now():
                # Defer, don't consume. A channel has no `status` fallback, so a
                # mail polled and skipped during quiet hours would be lost
                # outright rather than merely delayed.
                await asyncio.sleep(POLL_INTERVAL)
                continue
            for fname, mail in watcher.poll():
                try:
                    await channel.send(format_agent_mail_msg(mail))
                except discord.HTTPException as e:
                    print(f"agent-mail send failed for {agent}/{fname}, "
                          f"will retry: {e}", file=sys.stderr)
                    continue
                watcher.commit(fname)
        except Exception as e:
            print(f"watch_agent_mailbox({agent}) loop error: {e}",
                  file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


def outbound_targets(agent: str, kind: str) -> list[dict]:
    """Channel entries that should receive `kind` events for `agent`. Empty
    list means no channel mapping — caller should fall back to user DM."""
    return [
        ch for ch in OUTBOUND_BY_AGENT.get(agent, [])
        if kind in ch['kinds']
    ]


async def watch_idea_claims(user: discord.User):
    claimed, file_existed = load_idea_claims()
    primed = file_existed
    while not client.is_closed():
        try:
            rc, out, err = run_mg(['list', '--status=claimed', '--json'])
            if rc != 0:
                print(f'watch_idea_claims mg list failed: {err.strip()[:200]}', file=sys.stderr)
                await asyncio.sleep(POLL_INTERVAL)
                continue

            fresh = set()
            titles = {}
            assignees = {}
            for line in out.splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if item.get('type') != 'idea':
                    continue
                iid = item.get('id')
                if not iid:
                    continue
                fresh.add(iid)
                titles[iid] = (item.get('title') or '?')[:80]
                assignees[iid] = (item.get('assignee') or '').strip()

            new_ids = fresh - claimed
            claimed = fresh

            if not primed:
                primed = True
            else:
                quiet_outbound = QUIET_RESPECTS_OUTBOUND and is_quiet_now()
                for iid in sorted(new_ids):
                    if quiet_outbound:
                        continue
                    assignee = assignees.get(iid, '') or 'architect'
                    targets = outbound_targets(assignee, 'idea-claims')
                    # Preserve v1.0.0 message format for the DM-fallback path
                    # (no channel mapping for assignee). Channel-routed messages
                    # use the actual assignee name so a non-architect claim
                    # routed to a channel isn't mislabeled.
                    if targets:
                        ch_msg = f'🧠 {assignee} claimed {iid}: {titles.get(iid, "?")}'
                        for ch in targets:
                            chan = client.get_channel(ch['snowflake'])
                            if chan is None:
                                continue
                            try:
                                await chan.send(ch_msg)
                            except discord.HTTPException as e:
                                print(f'idea-claim channel send failed: {e}', file=sys.stderr)
                    else:
                        msg = f'🧠 architect claimed {iid}: {titles.get(iid, "?")}'
                        try:
                            await user.send(msg)
                        except discord.HTTPException as e:
                            print(f'idea-claim send failed: {e}', file=sys.stderr)

            save_idea_claims(claimed)
        except Exception as e:
            print(f'watch_idea_claims loop error: {e}', file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


async def watch_task_transitions(user: discord.User):
    states, file_existed = load_task_states()
    primed = file_existed  # if cache file existed, treat first tick as a normal diff
    while not client.is_closed():
        try:
            rc, out, err = run_mg(['list', '--json', '--all'])
            if rc != 0:
                print(f'watch_task_transitions mg list failed: {err.strip()[:200]}', file=sys.stderr)
                await asyncio.sleep(POLL_INTERVAL)
                continue

            seen_ids = set()
            transitions: list[tuple[str, str]] = []  # (msg, assignee)
            for line in out.splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    task = json.loads(line)
                except json.JSONDecodeError:
