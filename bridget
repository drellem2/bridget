                if task.get('type') != 'task':
                    continue
                tid = task.get('id')
                status = task.get('status')
                if not tid or not status:
                    continue
                seen_ids.add(tid)
                prev = states.get(tid)
                if primed and prev != status and status in _TRANSITION_FORMATS:
                    msg = format_transition(task, status)
                    if msg:
                        assignee = (task.get('assignee') or '').strip()
                        transitions.append((msg, assignee))
                states[tid] = status

            for stale in set(states.keys()) - seen_ids:
                del states[stale]

            if not primed:
                primed = True
            else:
                quiet_outbound = QUIET_RESPECTS_OUTBOUND and is_quiet_now()
                for msg, assignee in transitions:
                    if quiet_outbound:
                        continue
                    targets = outbound_targets(assignee, 'task-transitions') if assignee else []
                    if targets:
                        for ch in targets:
                            chan = client.get_channel(ch['snowflake'])
                            if chan is None:
                                continue
                            try:
                                await chan.send(msg)
                            except discord.HTTPException as e:
                                print(f'task-transition channel send failed: {e}',
                                      file=sys.stderr)
                    else:
                        try:
                            await user.send(msg)
                        except discord.HTTPException as e:
                            print(f'task-transition send failed: {e}', file=sys.stderr)

            save_task_states(states)
        except Exception as e:
            print(f'watch_task_transitions loop error: {e}', file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


def run_mg(args: list[str]) -> tuple[int, str, str]:
    try:
        r = subprocess.run(
            [MG_BIN, *args],
            capture_output=True, text=True, timeout=30,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', 'mg command timed out'
    except FileNotFoundError:
        return 127, '', f'mg not found at {MG_BIN}'


def run_pogo(args: list[str]) -> tuple[int, str, str]:
    pogo_bin = CONFIG.get('pogo_bin') or shutil.which('pogo')
    if not pogo_bin:
        return 1, '', 'pogo binary not found (install pogo or set POGO_BIN)'
    try:
        r = subprocess.run(
            [pogo_bin, *args],
            capture_output=True, text=True, timeout=30,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', 'pogo command timed out'


def run_shell(args: list[str], timeout: int = 30, cwd=None) -> tuple[int, str, str]:
    try:
        r = subprocess.run(
            args, capture_output=True, text=True, timeout=timeout, cwd=cwd,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', f'command timed out: {args[0] if args else "?"}'
    except FileNotFoundError:
        return 127, '', f'command not found: {args[0] if args else "?"}'


def find_mails_for(mg_id: str) -> list:
    """Return [(path, mail_dict, dir_name)] for mails referencing mg_id, newest first."""
    out = []
    needle = mg_id.lower()
    for d in ('new', 'cur'):
        ddir = MAIL_DIR.parent / d
        if not ddir.exists():
            continue
        for p in sorted(ddir.iterdir(), reverse=True):
            try:
                content = p.read_text()
                if needle in content.lower():
                    out.append((p, parse_mail(content), d))
            except Exception:
                pass
    return out


def mark_mail_read(mg_id=None, all_unread: bool = False) -> int:
    """Move mails from human/new/ → human/cur/. If mg_id is set, only mails
    whose subject/body references that id; if all_unread is True, every mail.
    Returns the count moved."""
    if not MAIL_DIR.exists():
        return 0
    cur_dir = MAIL_DIR.parent / 'cur'
    cur_dir.mkdir(parents=True, exist_ok=True)
    n = 0
    for p in sorted(MAIL_DIR.iterdir()):
        try:
            if all_unread:
                p.rename(cur_dir / p.name)
                n += 1
                continue
            if mg_id is None:
                continue
            content = p.read_text()
            # Match the mg-id case-insensitively; covers headers and body.
            if mg_id.lower() in content.lower():
                p.rename(cur_dir / p.name)
                n += 1
        except Exception as e:
            print(f"mark_mail_read error on {p.name}: {e}", file=sys.stderr)
    return n


def scan_pending_approvals() -> list[str]:
    """Subjects of unread mails in human/new/ that are approval requests."""
    if not MAIL_DIR.exists():
        return []
    out = []
    for p in sorted(MAIL_DIR.iterdir()):
        try:
            for line in p.read_text().splitlines():
                if line == '':
                    break
                if APPROVAL_RE.match(line):
                    out.append(line[len('Subject: '):] if line.startswith('Subject: ') else line)
                    break
        except Exception:
            pass
    return out


def get_status_summary() -> str:
    """Global pull view: unread mail count, pending approvals, in-flight work."""
    parts = []

    unread = sorted(MAIL_DIR.iterdir()) if MAIL_DIR.exists() else []
    parts.append(f"📬 Unread mail to human: **{len(unread)}**")

    if unread:
        for p in unread:
            try:
                mail = parse_mail(p.read_text())
                haystack = (mail['subject'] + ' ' + mail['body']).lower()
                ids = sorted(set(re.findall(r'mg-[0-9a-f]+', haystack)))
                id_str = ', '.join(ids) if ids else '(no mg-id)'
                subj = mail['subject'][:60]
                parts.append(f'  • [{id_str}] {mail["from"]}: {subj}')
            except Exception:
                parts.append(f'  • (parse error: {p.name})')

    approvals = scan_pending_approvals()
    if approvals:
        parts.append("\n**Pending approvals:**")
        for s in approvals:
            parts.append(f"• {s}")

    rc, out, err = run_mg(['list', '--json'])
    in_flight = []
    if rc == 0:
        for line in out.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
                if d.get('status') in ('available', 'claimed', 'pending'):
                    in_flight.append(d)
            except json.JSONDecodeError:
                pass
    elif err:
        parts.append(f"\n(mg list error: {err.strip()[:200]})")

    if in_flight:
        parts.append("\n**In-flight work:**")
        for d in in_flight:
            iid = d.get('id', '?')
            status = d.get('status', '?')
            title = (d.get('title') or '?')[:80]
            assignee = d.get('assignee') or '—'
            parts.append(f"• [{iid}] {status}: {title} (→ {assignee})")
    else:
        parts.append("\n**In-flight work:** (none)")

    return '\n'.join(parts)


def handle_command(text: str) -> str:
    text = text.strip()
    low = text.lower()

    if low.startswith('approve mg-'):
        parts = text.split(None, 1)
        mg_id = parts[1] if len(parts) > 1 else ''
        rc, out, err = run_mg([
            'mail', 'send', WORKFLOW_AGENT,
            '--from=human',
            f'--subject=approve {mg_id}',
            '--body=approved via discord',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ approve sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('reject mg-'):
        parts = text.split(None, 2)
        if len(parts) < 2:
            return "Usage: `reject mg-XXXX <reason>`"
        mg_id = parts[1]
        reason = parts[2] if len(parts) > 2 else 'rejected via discord'
        rc, out, err = run_mg([
            'mail', 'send', WORKFLOW_AGENT,
            '--from=human',
            f'--subject=reject {mg_id}',
            f'--body={reason}',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ reject sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('revise mg-'):
        parts = text.split(None, 2)
        if len(parts) < 3:
            return "Usage: `revise mg-XXXX <feedback>`"
        mg_id = parts[1]
        feedback = parts[2]
        sh_rc, sh_out, _ = run_mg(['show', mg_id])
        if sh_rc == 0 and re.search(r'^Status:\s+shelved', sh_out, re.MULTILINE):
            run_mg(['unshelve', mg_id])
        rc, out, err = run_mg([
            'mail', 'send', WORKFLOW_AGENT,
            '--from=human',
            f'--subject=revise {mg_id}',
            f'--body={feedback}',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ revise sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('read mg-'):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `read mg-XXXX`"
        mg_id = parts[1].strip()
        matches = find_mails_for(mg_id)
        if not matches:
            return f"No mail found for `{mg_id}`."
        p, mail, dir_name = matches[0]
        state = "unread" if dir_name == 'new' else "read"
        rest = len(matches) - 1
        rest_note = f"\n\n_({rest} other mail{'s' if rest != 1 else ''} also reference this id; this is the newest.)_" if rest else ''
        out = (
            f"📧 from `{mail['from']}` _({state})_\n"
            f"**{mail['subject']}**\n\n"
            f"{mail['body']}"
            f"{rest_note}"
        )
        if dir_name == 'new':
            cur_dir = MAIL_DIR.parent / 'cur'
            cur_dir.mkdir(parents=True, exist_ok=True)
            try:
                p.rename(cur_dir / p.name)
            except Exception as e:
                print(f'auto-mark-read failed for {p.name}: {e}', file=sys.stderr)
        return out

    if low.startswith('dismiss '):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `dismiss mg-XXXX` or `dismiss all`"
        target = parts[1].strip()
        if target.lower() == 'all':
            n = mark_mail_read(all_unread=True)
            return f"✓ marked {n} mail{'s' if n != 1 else ''} read (inbox-zero)"
        if target.lower().startswith('mg-'):
            n = mark_mail_read(mg_id=target)
            return f"✓ marked {n} mail{'s' if n != 1 else ''} read for `{target}`"
        return "Usage: `dismiss mg-XXXX` or `dismiss all`"

    if low.startswith('next mg-'):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `next mg-XXXX`"
        parent_id = parts[1].strip()
        design_path = DESIGNS_DIR / f"{parent_id}.md"
        if not design_path.exists():
            return f"No design doc found for `{parent_id}`."
        try:
            content = design_path.read_text()
        except Exception as e:
            return f"Failed to read design: {e}"
        rm = re.search(r'^## Roadmap[^\n]*\n(.*?)(?=^## |\Z)', content, re.MULTILINE | re.DOTALL)
        if not rm:
            return f"No Roadmap section in `{parent_id}`'s design."
        roadmap_body = rm.group(1)
        tm = re.search(r'^(### Task \d+[^\n]*)\n(.*?)(?=^### |\Z)', roadmap_body, re.MULTILINE | re.DOTALL)
        if not tm:
            return f"No tasks remaining in `{parent_id}`'s Roadmap."
        heading = tm.group(1).strip()
        body_text = tm.group(2).strip()
        name_match = re.search(r'`([^`]+)`', heading)
        short_name = name_match.group(1) if name_match else heading[:60]
        idea_body = (
            f"From {parent_id}'s Roadmap: {heading}\n\n"
            f"Parent design: {design_path}\n\n"
            f"---\n\n{body_text}"
        )
        rc, out, err = run_mg([
            'new', '--type=idea',
            f'--title=Roadmap: {short_name}',
            f'--body={idea_body}',
            f'--assignee={WORKFLOW_AGENT}',
            f'--tag={INBOX_TAG}',
            f'--repo={INBOX_REPO}',
        ])
        return f"✓ next idea filed:\n{code_block(out.strip())}" if rc == 0 else f"✗ failed: {err or out}"

    if low.startswith('explain mg-'):
        parts = text.split(None, 2)
        if len(parts) < 3:
            return "Usage: `explain mg-XXXX <what to explain>`"
        mg_id = parts[1]
        topic = parts[2]
        rc, out, err = run_mg([
            'mail', 'send', WORKFLOW_AGENT,
            '--from=human',
            f'--subject=explain {mg_id}',
            f'--body={topic}',
        ])
        return f"✓ explain request sent: `{mg_id}`" if rc == 0 else f"✗ failed: {err or out}"

    if low == 'agents' or low == 'agent list' or low == 'crew':
        rc, out, err = run_pogo(['agent', 'list', '--json'])
        if rc != 0:
            return f'✗ pogo agent list failed: {err or out}'
        try:
            agents_list = json.loads(out)
        except json.JSONDecodeError as e:
            return f'✗ failed to parse agent list: {e}'
        if not agents_list:
            return '🤖 No crew agents registered.'
        lines = [f'🤖 **Crew agents ({len(agents_list)}):**']
        for a in agents_list:
            name = a.get('name', '?')
            rc2, dout, _ = run_pogo(['agent', 'diagnose', name, '--json'])
            health = '?'
            if rc2 == 0:
                try:
                    health = json.loads(dout).get('health', '?')
                except json.JSONDecodeError:
                    pass
            status = a.get('status', '?')
            cycle = agent_cycle_paren(name)
            lines.append(f'  • {name:<12} — {status}, {health:<10} {cycle}')
        return '\n'.join(lines)

    if low == 'balance':
        rc, out, err = run_pogo(['agent', 'list', '--json'])
        if rc != 0:
            return f'✗ pogo agent list failed: {(err or out).strip()[:200]}'
        try:
            agents_list = json.loads(out)
        except json.JSONDecodeError as e:
            return f'✗ failed to parse agent list: {e}'
        now_utc = datetime.datetime.now(datetime.timezone.utc)
        hits = []
        for a in agents_list:
            name = a.get('name', '?')
            rc2, dout, _ = run_pogo(['agent', 'diagnose', name, '--json'])
            if rc2 != 0:
                continue
            try:
                diag = json.loads(dout)
            except json.JSONDecodeError:
                continue
            tail = diag.get('recent_output_tail') or ''
            if not CREDIT_BALANCE_RE.search(tail):
                continue
            last_activity = diag.get('last_activity') or ''
            try:
                ts = _parse_iso_utc(last_activity)
                ago = humanize_ago((now_utc - ts).total_seconds())
            except Exception:
                ago = '?'
            hits.append((name, ago))
        if not hits:
            return '✅ no credit balance errors detected in recent agent activity.'
        lines = ['🚨 credit balance errors detected:']
        for name, ago in hits:
            lines.append(f'  • {name} — last seen {ago}')
        lines.append('Refuel at console.anthropic.com.')
        return '\n'.join(lines)

    if low.startswith('nudge '):
        parts = text.split(None, 2)
        if len(parts) < 2:
            return 'Usage: nudge <agent-name> [reason]'
        agent_name = parts[1]
        reason = parts[2] if len(parts) > 2 else 'status check'
        rc, out, err = run_pogo(['nudge', agent_name, reason])
        if rc == 0:
            return f'✓ nudged {agent_name}: "{reason}"'
        return f'✗ nudge failed: {err or out}'

    if low == 'restart':
        rc, out, err = run_shell(
            ['git', '-C', str(BRIDGET_REPO), 'pull', '--ff-only'], timeout=30,
        )
        if rc != 0:
            return f'❌ git pull failed: {(err or out).strip()[:200]}; staying on old code.'
        rc_sha, sha_out, _ = run_shell(
            ['git', '-C', str(BRIDGET_REPO), 'rev-parse', '--short', 'HEAD'], timeout=10,
        )
        sha = sha_out.strip() if rc_sha == 0 else '?'
        rc_b, _, err_b = run_shell(
            RESTART_CMD, timeout=10, cwd=str(BRIDGET_REPO),
        )
        if rc_b != 0:
            return f'❌ syntax check failed: {err_b.strip()[:200]}; staying on old code.'
        # 2s gives the Discord ack time to flush before launchd respawns us.
        client.loop.call_later(2.0, lambda: os._exit(0))
        return f'✅ pulled {sha}; restarting in 2s'

    if low == 'mail' or low.startswith('mail '):
        rest = text[len('mail'):].lstrip()
        if '\n' in rest:
            subject, body = rest.split('\n', 1)
            subject = subject.strip()
            body = body.rstrip()
        else:
            subject = rest.strip()
            body = '(no body)'
        if not subject:
            return 'Usage: mail <subject>\n[optional body, multi-line OK]'
        recipient = CONFIG['mail_recipient']
        rc, out, err = run_mg([
            'mail', 'send', recipient,
            '--from=human',
            f'--subject={subject}',
            f'--body={body}',
        ])
        if rc == 0:
            return f'✓ mailed {recipient}: "{subject[:60]}"'
        return f'✗ mail failed: {(err or out).strip()[:200]}'

    if low in ('help', '?', 'commands'):
        return "**Commands:**\n" + COMMAND_LIST

    if low.startswith('idea:'):
        body = text[5:].strip()
        if not body:
            return "Usage: `idea: [optional-tag] <description>`"
        extra_tags = []
        m = re.match(r'^\[([^\]]+)\]\s*(.*)$', body, re.DOTALL)
        if m:
            extra_tags.append(m.group(1).strip())
            body = m.group(2).strip()
        if not body:
            return "Usage: `idea: [optional-tag] <description>`"
        title = body.splitlines()[0][:60]
        args = [
            'new', '--type=idea',
            f'--title={title}',
            f'--body={body}',
            f'--assignee={WORKFLOW_AGENT}',
            f'--tag={INBOX_TAG}',
            f'--repo={INBOX_REPO}',
        ]
        for t in extra_tags:
            args.append(f'--tag={t}')
        rc, out, err = run_mg(args)
        return f"✓ idea filed:\n{code_block(out.strip())}" if rc == 0 else f"✗ failed: {err or out}"

    if low.startswith('bug:'):
        body = text[4:].strip()
        if not body:
            return "Usage: `bug: [optional-tag] <description>`"
        extra_tags = []
        m = re.match(r'^\[([^\]]+)\]\s*(.*)$', body, re.DOTALL)
        if m:
            extra_tags.append(m.group(1).strip())
            body = m.group(2).strip()
        if not body:
            return "Usage: `bug: [optional-tag] <description>`"
        title = body.splitlines()[0][:60]
        args = [
            'new', '--type=bug',
            f'--title={title}',
            f'--body={body}',
            f'--assignee={WORKFLOW_AGENT}',
            f'--tag={INBOX_TAG}',
            f'--repo={INBOX_REPO}',
        ]
        for t in extra_tags:
            args.append(f'--tag={t}')
        rc, out, err = run_mg(args)
        return f"✓ bug filed:\n{code_block(out.strip())}" if rc == 0 else f"✗ failed: {err or out}"

    if low == 'quiet' or low.startswith('quiet '):
        rest = text.split()[1:]
        if not rest or (len(rest) == 1 and rest[0].lower() == 'status'):
            state = load_quiet()
            if state['enabled']:
                return f"🌙 quiet hours: enabled, {state['start']}–{state['end']} (local)."
            return f"quiet hours: disabled. (window {state['start']}–{state['end']})"
        if len(rest) == 2 and TIME_RE.match(rest[0]) and TIME_RE.match(rest[1]):
            return "Usage: `quiet <true|false> [HH:MM HH:MM]`"
        flag = rest[0].lower()
        if flag not in ('true', 'false'):
            return "Usage: `quiet <true|false> [HH:MM HH:MM]`"
        state = load_quiet()
        times = rest[1:]
        if times:
            if len(times) != 2 or not TIME_RE.match(times[0]) or not TIME_RE.match(times[1]):
                return "Usage: `quiet <true|false> [HH:MM HH:MM]` (times must match HH:MM)"
            state['start'] = times[0]
            state['end'] = times[1]
        if flag == 'true':
            state['enabled'] = True
            save_quiet(state)
            return f"✓ quiet hours: enabled, {state['start']}–{state['end']} (local)."
        state['enabled'] = False
        save_quiet(state)
        return f"✓ quiet hours: disabled. (window {state['start']}–{state['end']} preserved for next enable)"

    if low == 'settings':
        subjects = {c.key: f'**{c.agent}** — {c.subject}' for c in CONVERSATIONS.values()}
        out = render_settings(SETTINGS.summary(subjects))
        if not THREADS_ENABLED:
            out += '\n• Threads: `off` (set BRIDGET_LOG_CHANNEL_ID to enable)'
        else:
            out += f'\n• Threads: `on` → <#{LOG_CHANNEL_ID}>'
            out += f'\n• Conversations tracked: **{len(CONVERSATIONS)}**'
        out += f'\n• Correlation IDs (reply threading): `{MG_CAPS.describe()}`'
        return out

    if low == 'dm' or low.startswith('dm '):
        arg = text[2:].strip().lower()
        if not arg:
            return f'DM policy is `{SETTINGS.dm_policy}`. Set with `dm <{" | ".join(DM_POLICIES)}>`.'
        if arg not in DM_POLICIES:
            return f'✗ unknown DM policy `{arg}`. Choose one of: {", ".join(DM_POLICIES)}.'
        if arg != 'all' and not THREADS_ENABLED:
            return (f'✗ `dm {arg}` needs a log channel, or suppressed mail would have\n'
                    f'nowhere to go. Set BRIDGET_LOG_CHANNEL_ID and restart.')
        SETTINGS.set_dm_policy(arg)
        return f'✓ DM policy: `{arg}`.'

    if low == 'mute all':
        if not SETTINGS.set_mute_all(True):
            return 'All DMs were already muted.'
        if THREADS_ENABLED:
            return '✓ all DMs muted. Mail still threads into the log channel.'
        # No log channel: the DM was the only push surface. Say so plainly
        # rather than claiming a log channel that does not exist. Nothing is
        # lost — the watcher stops consuming mail while muted, so `unmute all`
        # delivers whatever arrived in the meantime.
        return ('✓ all DMs muted. With no log channel this is your only surface, '
                'so nothing will be pushed until you `unmute all` — mail is held, '
                'not dropped. `status` still shows it.')

    if low == 'unmute all':
        return ('✓ DMs unmuted.' if SETTINGS.set_mute_all(False)
                else 'DMs were not muted.')

    if low in ('mute', 'unmute'):
        return (f'Reply `{low}` inside a conversation thread to act on that '
                f'conversation, or `{low} all` to act on every DM.')

    if low == 'status' or low.startswith('status'):
        summary = get_status_summary()
        if len(summary) > STATUS_OUTPUT_BUDGET:
            summary = summary[:STATUS_OUTPUT_BUDGET] + '\n…(truncated)'
        try:
            run_pogo(['nudge', 'crew-mayor', 'status check from human via bridge'])
        except Exception as e:
            print(f'mayor nudge failed: {e}', file=sys.stderr)
        return summary

    return UNRECOGNIZED_REPLY


def handle_thread_message(text: str, conv) -> str:
    """A message typed inside a conversation thread.

    `mute` / `unmute` act on *this* conversation — that is the whole ergonomic
    win of threads, since the human never has to name the thing they're looking
    at. Anything else is a reply, mailed back to the agent with the reply
    threaded onto the conversation.
    """
    low = text.strip().lower()

    if low == 'mute':
        return ('🔕 muted — this conversation stops DMing you. It keeps threading '
                'here. `unmute` to undo.' if SETTINGS.mute(conv.key)
                else 'Already muted.')
    if low == 'unmute':
        return ('🔔 unmuted.' if SETTINGS.unmute(conv.key)
                else 'This conversation was not muted.')
    if low in ('help', '?'):
        return ('In a thread: type a reply to mail it back to '
                f'`{conv.agent}`, or `mute` / `unmute` this conversation.\n\n'
                + COMMAND_LIST)

    # A workflow verb typed in a thread still means what it means everywhere
    # else — approving a design shouldn't depend on which surface you typed it
    # into. But only the unambiguous ones: in a thread the default reading of
    # what the human typed is "this is a reply", not "this is a command".
    if THREAD_VERB_RE.match(text):
        reply = handle_command(text)
        if reply != UNRECOGNIZED_REPLY:
            return reply

    return render_ack(reply_in_conversation(text, conv))


def send_channel_chat_mail(text: str, agent: str) -> str:
    """Plain-text message in a mapped guild channel becomes a mail to that
    channel's agent. Splits on the first newline to mimic the `mail` verb's
    subject/body convention so the recipient sees a proper subject line."""
    text = text.strip()
    if not text:
        return ''
    if '\n' in text:
        subject, body = text.split('\n', 1)
        subject = subject.strip()
        body = body.rstrip()
    else:
        subject = text
        body = '(no body)'
    rc, out, err = run_mg(build_send_args(agent, subject, body, sender='human'))
    if rc == 0:
        return f'✓ mailed `{agent}`: "{subject[:60]}"'
    return f'✗ mail failed: {(err or out).strip()[:200]}'


def reply_in_conversation(text: str, conv) -> acks.Ack:
    """Mail a thread reply back to the agent on the other end.

    This is what the correlation-ID work buys: `--in-reply-to` threads the reply
    onto the newest message in the chain, so the agent's mailbox shows a real
    conversation rather than a pile of unrelated top-level mails, and the agent's
    own reply comes back carrying References that route it to this same thread.

    That last clause only holds because we fold the id mg assigned *this* reply
    back into the conversation. The agent answers our message, so its reply
    names our id and no other; a conversation that forgot what it said could not
    recognize the answer, and would root a second thread for it.

    Every line the human types is body, and the subject is always
    `Re: <conversation subject>` (A4). The `mail` verb splits the first line off
    as a subject, and this used to mirror it — but the two are different acts.
    Composing a new mail needs a subject, so the human supplies one. Replying
    inside a thread does not: the subject is already known, it is on the thread
    they are looking at, and taking their first sentence for it both breaks
    subject continuity for the agent and reads as a non-sequitur in its inbox.
    `send_channel_chat_mail` still splits, because there the human is composing.
    """
    text = text.strip()
    if not text:
        return acks.undeliverable('empty message')
    if not conv.agent or conv.agent == '?':
        return acks.undeliverable(
            'this conversation has no known sender to reply to', agent=conv.agent)

    # `conv.subject` has already had any `Re:` stripped by `thread_title`, so
    # this cannot stack up. An unnamed conversation is named after its agent —
    # mg refuses a blank --subject.
    body = text
    subject = f'Re: {conv.subject or f"mail from {conv.agent}"}'

    # The seam. Threading needs both a known parent id and an mg that speaks
    # --in-reply-to; missing either, the reply still goes out, just untethered.
    threading = MG_CAPS.correlation_ids
    in_reply_to = conv.last_message_id if threading else ''

    rc, out, err = run_mg(build_send_args(
        conv.agent, subject, body, sender='human', in_reply_to=in_reply_to,
        want_msg_id=threading))

    rejected = err or out
    if rc != 0 and threading and (is_unknown_flag_error(rejected)
                                  or is_unknown_flag_error(rejected, FLAG_JSON)):
        # mg was swapped under us (an unrelated `go install` will do it), or an
        # operator forced correlation IDs on for a build too old to have them.
        # Either way the cached capability is stale — downgrade and resend,
        # rather than telling the human their reply was undeliverable when it
        # plainly is not. We check both flags: with no parent id to thread onto
        # `--json` goes out alone, and it is then the one mg names.
        print('mg rejected a correlation-ID flag; disabling correlation IDs for '
              'this process and retrying without threading', file=sys.stderr)
        MG_CAPS.downgrade()
        in_reply_to = ''
        rc, out, err = run_mg(build_send_args(
            conv.agent, subject, body, sender='human'))

    if rc != 0:
        return acks.undeliverable((err or out).strip(), agent=conv.agent)

    sent_id = parse_sent_message_id(out)
    if sent_id:
        CONVERSATIONS.record(conv.key, message_id=sent_id)
    return acks.delivered(conv.agent, subject, in_reply_to=in_reply_to)


def recent_conversations(limit: int = 5) -> list:
    """(label, key) for the most recently active conversations, newest first."""
    convs = sorted(CONVERSATIONS.values(), key=lambda c: c.updated_at, reverse=True)
    return [(f'**{c.agent}** — {c.subject}', c.key) for c in convs[:limit]]


def handle_channel_message(text: str, channel_entry: dict) -> str:
    """Route an inbound guild-channel message. Workflow verbs (approve/reject/
    revise/idea:/etc.) keep routing through `POGO_WORKFLOW_AGENT` exactly like
    they do in DMs — design coordination shouldn't change identity based on
    where the human typed. Anything else (free-form chat) becomes a mail to the
    channel's mapped agent."""
    reply = handle_command(text)
    if reply == UNRECOGNIZED_REPLY:
        return send_channel_chat_mail(text, channel_entry['agent'])
    return reply


@client.event
async def on_ready():
    print(f"logged in as {client.user} (id={client.user.id})", flush=True)
    try:
        user = await client.fetch_user(USER_ID)
    except discord.NotFound:
        print(f"user {USER_ID} not found", file=sys.stderr)
        await client.close()
        return
    if THREADS_ENABLED:
        print(f"threading on: conversations root in channel {LOG_CHANNEL_ID}; "
              f"{len(CONVERSATIONS)} conversation(s) restored; "
              f"dm_policy={SETTINGS.dm_policy}", flush=True)
    else:
        print("threading off: set BRIDGET_LOG_CHANNEL_ID to enable "
              "thread-per-conversation", flush=True)
    # Probes `mg mail send --help` once. Replies still deliver when this is
    # off; they just arrive as new top-level mail instead of threading.
    print(f"correlation IDs (mg --in-reply-to): {MG_CAPS.describe()}", flush=True)

    client.loop.create_task(watch_mailbox(user))
    client.loop.create_task(watch_task_transitions(user))
    client.loop.create_task(watch_idea_claims(user))

    # Per-channel mailbox fan-out: one watcher per outbound channel mapping
    # whose `kinds` includes 'mail'. Each watcher uses ~/.pogo/bridget.seen.<agent>
    # for its own in-memory seen-state copy; if two channels map the same
    # agent's mail, they each deliver one copy and overwrite the same seen
    # file with the same contents — both channels still receive every mail.
    started_agents: set[str] = set()
    for entry in CHANNELS.values():
        if entry['direction'] not in ('outbound', 'both'):
            continue
        if 'mail' not in entry['kinds']:
            continue
        client.loop.create_task(watch_agent_mailbox(entry))
        started_agents.add(entry['agent'])
    if started_agents:
        print(f"spawned per-channel mailbox watchers for: "
              f"{', '.join(sorted(started_agents))}", flush=True)


@client.event
async def on_message(message: discord.Message):
    if message.author.bot:
        return
    if message.author.id != USER_ID:
        return

    channel = message.channel

    if isinstance(channel, discord.DMChannel):
        reply = handle_command(message.content)
    elif isinstance(channel, discord.Thread):
        # A conversation thread we opened: the message is a reply to that
        # conversation. Threads we don't own (the human's own, or another
        # bot's) are ignored, same as unmapped channels.
        conv = CONVERSATIONS.by_thread(channel.id)
        if conv is None:
            return
        SETTINGS.reload_if_changed()
        reply = handle_thread_message(message.content, conv)
    elif THREADS_ENABLED and channel.id == LOG_CHANNEL_ID:
        # Free-form text in the log channel itself, outside any thread. We
        # cannot know which conversation it answers — say so, and show what it
        # might have meant, rather than silently doing nothing or guessing.
        reply = handle_command(message.content)
        if reply == UNRECOGNIZED_REPLY:
            reply = render_ack(acks.ambiguous(recent_conversations()))
    else:
        # Guild text channel: only respond if it's mapped for inbound routing.
        # Unmapped channels are ignored silently — bridget shouldn't chat in
        # arbitrary guild channels just because the bot is in the server.
        channel_entry = CHANNELS_BY_SNOWFLAKE.get(channel.id)
        if channel_entry is None:
            return
        reply = handle_channel_message(message.content, channel_entry)

    if not reply:
        return
    if len(reply) > DISCORD_MSG_LIMIT:
        reply = reply[:DISCORD_MSG_LIMIT] + '…'
    try:
        await message.channel.send(reply)
    except discord.HTTPException as e:
        print(f"reply send failed: {e}", file=sys.stderr)


