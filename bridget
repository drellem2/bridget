"""
Pogo ↔ Discord bridge.

- Watches the human-mail directory and DMs the configured user when new mail
  arrives.
- Listens to DMs from the configured user; routes recognized commands to mg.

Configuration is read from ~/.pogo/bridget.env (key=value lines).

Required keys:
    DISCORD_BOT_TOKEN, DISCORD_USER_ID, DISCORD_SERVER_ID

Optional keys:
    MG_BIN           — full path to the mg binary (otherwise resolved on PATH)
    POGO_MAIL_DIR    — parent of new/ and cur/ (default: ~/.macguffin/mail/human)
    POGO_DESIGNS_DIR — directory containing mg-XXXX.md design docs (no default)
    POGO_INBOX_REPO  — repo to file new ideas into via mg new (no default)

Tracks already-delivered mails in ~/.pogo/bridget.seen so a restart doesn't
re-deliver the entire backlog.
"""
from __future__ import annotations

import asyncio
import datetime
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

HOME = Path.home()
ENV_FILE = HOME / '.pogo' / 'bridget.env'
SEEN_FILE = HOME / '.pogo' / 'bridget.seen'
QUIET_FILE = HOME / '.pogo' / 'quiet.json'
TASK_STATES_FILE = HOME / '.pogo' / 'bridget.task-states.json'
IDEA_CLAIMS_FILE = HOME / '.pogo' / 'bridget.idea-claims.json'
AGENT_STATUS_DIR = HOME / '.pogo' / 'agent-status'
AGENT_STATUS_STALE = datetime.timedelta(minutes=30)
INSTALL_DOCS_URL = 'https://github.com/CloverRoss/bridget#readme'
BRIDGET_REPO = Path(os.environ.get(
    'BRIDGET_REPO_DIR',
    str(Path(__file__).resolve().parent),
))

POLL_INTERVAL = 5  # seconds
DISCORD_MSG_LIMIT = 1900  # leave headroom under the 2000 char limit
STATUS_OUTPUT_BUDGET = 1700


def die(msg: str, code: int = 1) -> None:
    print(f"bridget: {msg}", file=sys.stderr)
    sys.exit(code)


def load_env_file(path: Path) -> dict:
    out = {}
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith('#') or '=' not in line:
            continue
        k, v = line.split('=', 1)
        out[k.strip()] = v.strip()
    return out


def load_config() -> dict:
    if not ENV_FILE.exists():
        die(
            f"config file not found: {ENV_FILE}\n"
            f"  copy bridget.env.example to {ENV_FILE} and fill in your\n"
            f"  Discord bot token + user/server IDs.\n"
            f"  see {INSTALL_DOCS_URL} for setup instructions."
        )

    file_env = load_env_file(ENV_FILE)

    def lookup(key: str) -> str | None:
        # Process env wins over the env file so launchd / systemd overrides work.
        return os.environ.get(key) or file_env.get(key)

    missing = [k for k in ('DISCORD_BOT_TOKEN', 'DISCORD_USER_ID', 'DISCORD_SERVER_ID')
               if not lookup(k)]
    if missing:
        die(
            f"missing required key(s) in {ENV_FILE}: {', '.join(missing)}\n"
            f"  see bridget.env.example for the full template."
        )

    try:
        user_id = int(lookup('DISCORD_USER_ID'))
        server_id = int(lookup('DISCORD_SERVER_ID'))
    except ValueError:
        die("DISCORD_USER_ID and DISCORD_SERVER_ID must be integers (Discord snowflake IDs).")

    mg_bin = lookup('MG_BIN') or shutil.which('mg')
    if not mg_bin:
        die(
            "could not find the `mg` binary on PATH.\n"
            "  install pogo and ensure `mg` is reachable, or set MG_BIN in\n"
            f"  {ENV_FILE} to its absolute path.\n"
            f"  see {INSTALL_DOCS_URL} for setup instructions."
        )
    if not Path(mg_bin).exists():
        die(f"MG_BIN points to a missing file: {mg_bin}")

    pogo_bin = lookup('POGO_BIN') or shutil.which('pogo')

    mail_parent_str = lookup('POGO_MAIL_DIR')
    mail_parent = Path(mail_parent_str).expanduser() if mail_parent_str \
        else HOME / '.macguffin' / 'mail' / 'human'

    designs_str = lookup('POGO_DESIGNS_DIR')
    designs_dir = Path(designs_str).expanduser() if designs_str else None

    inbox_str = lookup('POGO_INBOX_REPO')
    inbox_repo = str(Path(inbox_str).expanduser()) if inbox_str else None

    mail_recipient = lookup('POGO_MAIL_RECIPIENT') or 'mayor'

    return {
        'token': lookup('DISCORD_BOT_TOKEN'),
        'user_id': user_id,
        'server_id': server_id,
        'mg_bin': mg_bin,
        'pogo_bin': pogo_bin,
        'mail_parent': mail_parent,
        'mail_dir': mail_parent / 'new',
        'designs_dir': designs_dir,
        'inbox_repo': inbox_repo,
        'mail_recipient': mail_recipient,
    }


CONFIG = load_config()
TOKEN = CONFIG['token']
USER_ID = CONFIG['user_id']
SERVER_ID = CONFIG['server_id']
MG_BIN = CONFIG['mg_bin']
MAIL_DIR = CONFIG['mail_dir']
DESIGNS_DIR = CONFIG['designs_dir']
INBOX_REPO = CONFIG['inbox_repo']


import discord  # noqa: E402  (deferred so config errors don't require the venv)

intents = discord.Intents.default()
intents.message_content = True
intents.dm_messages = True

client = discord.Client(intents=intents)


def parse_mail(content: str) -> dict:
    lines = content.splitlines()
    headers = {}
    body_start = len(lines)
    for i, line in enumerate(lines):
        if line == '':
            body_start = i + 1
            break
        if ': ' in line:
            k, v = line.split(': ', 1)
            headers[k.lower()] = v
    body = '\n'.join(lines[body_start:])
    return {
        'from': headers.get('from', '?'),
        'subject': headers.get('subject', '?'),
        'body': body,
    }


def load_seen() -> set:
    if SEEN_FILE.exists():
        return set(SEEN_FILE.read_text().splitlines())
    return set()


def save_seen(seen: set) -> None:
    SEEN_FILE.write_text('\n'.join(sorted(seen)))


QUIET_DEFAULTS = {'enabled': False, 'start': '23:00', 'end': '06:00'}
TIME_RE = re.compile(r'^[0-2]\d:[0-5]\d$')


def load_quiet() -> dict:
    """Read ~/.pogo/quiet.json. Missing/unreadable file → defaults."""
    if not QUIET_FILE.exists():
        return {**QUIET_DEFAULTS, 'updated_at': ''}
    try:
        d = json.loads(QUIET_FILE.read_text())
    except Exception as e:
        print(f'load_quiet parse error: {e}', file=sys.stderr)
        return {**QUIET_DEFAULTS, 'updated_at': ''}
    return {
        'enabled': bool(d.get('enabled', False)),
        'start': d.get('start') or QUIET_DEFAULTS['start'],
        'end': d.get('end') or QUIET_DEFAULTS['end'],
        'updated_at': d.get('updated_at', ''),
    }


def save_quiet(state: dict) -> None:
    """Atomically write ~/.pogo/quiet.json with all schema keys populated."""
    QUIET_FILE.parent.mkdir(parents=True, exist_ok=True)
    out = {
        'enabled': bool(state.get('enabled', False)),
        'start': state.get('start') or QUIET_DEFAULTS['start'],
        'end': state.get('end') or QUIET_DEFAULTS['end'],
        'updated_at': datetime.datetime.now().astimezone().isoformat(timespec='seconds'),
    }
    tmp = QUIET_FILE.parent / (QUIET_FILE.name + '.tmp')
    tmp.write_text(json.dumps(out, indent=2) + '\n')
    os.replace(tmp, QUIET_FILE)


def load_task_states() -> tuple[dict, bool]:
    """Read the task-state cache. Returns (states, file_existed). Missing or
    malformed → empty dict + False so callers can prime silently."""
    if not TASK_STATES_FILE.exists():
        return {}, False
    try:
        d = json.loads(TASK_STATES_FILE.read_text())
        if not isinstance(d, dict):
            raise ValueError('not a dict')
        return {k: str(v) for k, v in d.items()}, True
    except Exception as e:
        print(f'load_task_states parse error: {e}', file=sys.stderr)
        return {}, True


def save_task_states(states: dict) -> None:
    """Atomically write the task-state cache."""
    TASK_STATES_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = TASK_STATES_FILE.parent / (TASK_STATES_FILE.name + '.tmp')
    tmp.write_text(json.dumps(states, indent=2, sort_keys=True) + '\n')
    os.replace(tmp, TASK_STATES_FILE)


def load_idea_claims() -> tuple[set, bool]:
    """Read the idea-claims cache. Returns (claimed_ids, file_existed).
    Missing or malformed → empty set + False so callers can prime silently."""
    if not IDEA_CLAIMS_FILE.exists():
        return set(), False
    try:
        d = json.loads(IDEA_CLAIMS_FILE.read_text())
        if isinstance(d, dict):
            ids = d.get('claimed_ids', [])
        elif isinstance(d, list):
            ids = d
        else:
            raise ValueError('not a dict or list')
        return {str(x) for x in ids}, True
    except Exception as e:
        print(f'load_idea_claims parse error: {e}', file=sys.stderr)
        return set(), True


def save_idea_claims(ids: set) -> None:
    """Atomically write the idea-claims cache."""
    IDEA_CLAIMS_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = IDEA_CLAIMS_FILE.parent / (IDEA_CLAIMS_FILE.name + '.tmp')
    payload = {'claimed_ids': sorted(ids)}
    tmp.write_text(json.dumps(payload, indent=2) + '\n')
    os.replace(tmp, IDEA_CLAIMS_FILE)


_TRANSITION_FORMATS = {
    'claimed': '🚀 claimed {id}{by}: {title}',
    'done': '✅ done {id}: {title}',
    'shelved': '📦 shelved {id}: {title}',
}
_NON_POLECAT_ASSIGNEES = {'architect', 'mayor', 'human', ''}


def format_transition(task: dict, new_status: str):
    fmt = _TRANSITION_FORMATS.get(new_status)
    if fmt is None:
        return None
    title = (task.get('title') or '?')[:80]
    by = ''
    if new_status == 'claimed':
        assignee = (task.get('assignee') or '').strip()
        if assignee and assignee.lower() not in _NON_POLECAT_ASSIGNEES:
            by = f' by {assignee}'
    return fmt.format(id=task.get('id', '?'), by=by, title=title)


def humanize_ago(seconds: float) -> str:
    """Compact 'time ago' formatter."""
    s = int(seconds)
    if s < 60:
        return 'just now'
    if s < 3600:
        return f'{s // 60}m ago'
    if s < 86400:
        return f'{s // 3600}h ago'
    return f'{s // 86400}d ago'


def _humanize_seconds(seconds: float) -> str:
    s = int(seconds)
    if s < 60:
        return f'{s}s'
    if s < 3600:
        m, sec = divmod(s, 60)
        return f'{m}m{sec:02d}s'
    h, rem = divmod(s, 3600)
    return f'{h}h{rem // 60}m'


def _parse_iso_utc(ts: str) -> datetime.datetime:
    if ts.endswith('Z'):
        ts = ts[:-1] + '+00:00'
    return datetime.datetime.fromisoformat(ts).astimezone(datetime.timezone.utc)


def agent_cycle_paren(name: str) -> str:
    """Return '(last cycle X ago, next cycle in Y)' read from
    ~/.pogo/agent-status/<name>.json, or '(last cycle ?, next cycle ?)' if the
    file is missing, malformed, or its updated_at is older than 30 minutes."""
    try:
        data = json.loads((AGENT_STATUS_DIR / f'{name}.json').read_text())
        last = _parse_iso_utc(data['last_cycle'])
        nxt = _parse_iso_utc(data['next_cycle'])
        updated = _parse_iso_utc(data['updated_at'])
        now = datetime.datetime.now(datetime.timezone.utc)
        if now - updated > AGENT_STATUS_STALE:
            return '(last cycle ?, next cycle ?)'
        last_ago = _humanize_seconds(max(0, (now - last).total_seconds()))
        delta = (nxt - now).total_seconds()
        if delta < 0:
            return f'(last cycle {last_ago} ago, next cycle overdue {_humanize_seconds(-delta)})'
        return f'(last cycle {last_ago} ago, next cycle in {_humanize_seconds(delta)})'
    except Exception:
        return '(last cycle ?, next cycle ?)'


async def watch_mailbox(user: discord.User):
    seen = load_seen()
    if not SEEN_FILE.exists() and MAIL_DIR.exists():
        for p in MAIL_DIR.iterdir():
            seen.add(p.name)
        save_seen(seen)
        try:
            await user.send(
                "🔔 bridget online. I'll DM you when new mail arrives in "
                "`human/new/`. Recognized replies:\n"
                "• `approve mg-XXXX` — approve a design\n"
                "• `reject mg-XXXX <reason>` — shelve it\n"
                "• `revise mg-XXXX <feedback>` — request changes (auto-unshelves if needed)\n"
                "• `idea: <text>` — file a new idea\n"
                "• `idea: [tag] <text>` — file with an extra scope tag (e.g. `[bridget]`)\n"
                "• `bug: <text>` — file a new bug (existing software is broken, not a new feature)\n"
                "• `bug: [tag] <text>` — file a bug with extra scope tag (e.g. `[discord-bridge]`)\n"
                "• `mail <subject>\\n<body>` — send a mail (without a newline, the whole text becomes the subject)\n"
                "• `status` — global pull view (unread mail + in-flight work)\n"
                "• `agents` — list crew agents and health\n"
                "• `restart` — git pull + restart bridget (after merging a PR)"
            )
        except discord.HTTPException as e:
            print(f"startup DM failed: {e}", file=sys.stderr)

    while not client.is_closed():
        try:
            if MAIL_DIR.exists():
                current = {p.name for p in MAIL_DIR.iterdir()}
                for fname in sorted(current - seen):
                    fpath = MAIL_DIR / fname
                    try:
                        mail = parse_mail(fpath.read_text())
                    except Exception as e:
                        print(f"parse error {fname}: {e}", file=sys.stderr)
                        seen.add(fname)
                        continue
                    body_preview = mail['body']
                    if len(body_preview) > 1200:
                        body_preview = body_preview[:1200] + '\n…[truncated; use `read <mg-id>`]'
                    msg = (
                        f"📬 **{mail['from']}** — {mail['subject']}\n"
                        f"```\n{body_preview}\n```"
                    )
                    if len(msg) > DISCORD_MSG_LIMIT:
                        msg = msg[:DISCORD_MSG_LIMIT] + '…'
                    try:
                        await user.send(msg)
                        seen.add(fname)
                    except discord.HTTPException as e:
                        print(f"send failed for {fname}: {e}", file=sys.stderr)
                save_seen(seen)
        except Exception as e:
            print(f"watch_mailbox loop error: {e}", file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


async def watch_idea_claims(user: discord.User):
    claimed, file_existed = load_idea_claims()
    primed = file_existed
    while not client.is_closed():
        try:
            rc, out, err = run_mg(['list', '--status=claimed', '--json'])
            if rc != 0:
                print(f'watch_idea_claims mg list failed: {err.strip()[:200]}', file=sys.stderr)
                await asyncio.sleep(POLL_INTERVAL)
                continue

            fresh = set()
            titles = {}
            for line in out.splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if item.get('type') != 'idea':
                    continue
                iid = item.get('id')
                if not iid:
                    continue
                fresh.add(iid)
                titles[iid] = (item.get('title') or '?')[:80]

            new_ids = fresh - claimed
            claimed = fresh

            if not primed:
                primed = True
            else:
                for iid in sorted(new_ids):
                    msg = f'🧠 architect claimed {iid}: {titles.get(iid, "?")}'
                    try:
                        await user.send(msg)
                    except discord.HTTPException as e:
                        print(f'idea-claim send failed: {e}', file=sys.stderr)

            save_idea_claims(claimed)
        except Exception as e:
            print(f'watch_idea_claims loop error: {e}', file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


async def watch_task_transitions(user: discord.User):
    states, file_existed = load_task_states()
    primed = file_existed  # if cache file existed, treat first tick as a normal diff
    while not client.is_closed():
        try:
            rc, out, err = run_mg(['list', '--json', '--all'])
            if rc != 0:
                print(f'watch_task_transitions mg list failed: {err.strip()[:200]}', file=sys.stderr)
                await asyncio.sleep(POLL_INTERVAL)
                continue

            seen_ids = set()
            transitions = []
            for line in out.splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    task = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if task.get('type') != 'task':
                    continue
                tid = task.get('id')
                status = task.get('status')
                if not tid or not status:
                    continue
                seen_ids.add(tid)
                prev = states.get(tid)
                if primed and prev != status and status in _TRANSITION_FORMATS:
                    msg = format_transition(task, status)
                    if msg:
                        transitions.append(msg)
                states[tid] = status

            for stale in set(states.keys()) - seen_ids:
                del states[stale]

            if not primed:
                primed = True
            else:
                for msg in transitions:
                    try:
                        await user.send(msg)
                    except discord.HTTPException as e:
                        print(f'task-transition send failed: {e}', file=sys.stderr)

            save_task_states(states)
        except Exception as e:
            print(f'watch_task_transitions loop error: {e}', file=sys.stderr)
        await asyncio.sleep(POLL_INTERVAL)


def run_mg(args: list[str]) -> tuple[int, str, str]:
    try:
        r = subprocess.run(
            [MG_BIN, *args],
            capture_output=True, text=True, timeout=30,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', 'mg command timed out'
    except FileNotFoundError:
        return 127, '', f'mg not found at {MG_BIN}'


def run_pogo(args: list[str]) -> tuple[int, str, str]:
    pogo_bin = CONFIG.get('pogo_bin') or shutil.which('pogo')
    if not pogo_bin:
        return 1, '', 'pogo binary not found (install pogo or set POGO_BIN)'
    try:
        r = subprocess.run(
            [pogo_bin, *args],
            capture_output=True, text=True, timeout=30,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', 'pogo command timed out'


def run_shell(args: list[str], timeout: int = 30, cwd=None) -> tuple[int, str, str]:
    try:
        r = subprocess.run(
            args, capture_output=True, text=True, timeout=timeout, cwd=cwd,
        )
        return r.returncode, r.stdout, r.stderr
    except subprocess.TimeoutExpired:
        return 124, '', f'command timed out: {args[0] if args else "?"}'
    except FileNotFoundError:
        return 127, '', f'command not found: {args[0] if args else "?"}'


def find_mails_for(mg_id: str) -> list:
    """Return [(path, mail_dict, dir_name)] for mails referencing mg_id, newest first."""
    out = []
    needle = mg_id.lower()
    for d in ('new', 'cur'):
        ddir = MAIL_DIR.parent / d
        if not ddir.exists():
            continue
        for p in sorted(ddir.iterdir(), reverse=True):
            try:
                content = p.read_text()
                if needle in content.lower():
                    out.append((p, parse_mail(content), d))
            except Exception:
                pass
    return out


def mark_mail_read(mg_id=None, all_unread: bool = False) -> int:
    """Move mails from human/new/ → human/cur/. If mg_id is set, only mails
    whose subject/body references that id; if all_unread is True, every mail.
    Returns the count moved."""
    if not MAIL_DIR.exists():
        return 0
    cur_dir = MAIL_DIR.parent / 'cur'
    cur_dir.mkdir(parents=True, exist_ok=True)
    n = 0
    for p in sorted(MAIL_DIR.iterdir()):
        try:
            if all_unread:
                p.rename(cur_dir / p.name)
                n += 1
                continue
            if mg_id is None:
                continue
            content = p.read_text()
            # Match the mg-id case-insensitively; covers headers and body.
            if mg_id.lower() in content.lower():
                p.rename(cur_dir / p.name)
                n += 1
        except Exception as e:
            print(f"mark_mail_read error on {p.name}: {e}", file=sys.stderr)
    return n


def scan_pending_approvals() -> list[str]:
    """Subjects of unread mails in human/new/ that are approval requests."""
    if not MAIL_DIR.exists():
        return []
    out = []
    for p in sorted(MAIL_DIR.iterdir()):
        try:
            for line in p.read_text().splitlines():
                if line == '':
                    break
                if line.startswith('Subject: approval needed '):
                    out.append(line[len('Subject: '):])
                    break
        except Exception:
            pass
    return out


def get_status_summary() -> str:
    """Global pull view: unread mail count, pending approvals, in-flight work."""
    parts = []

    unread = sorted(MAIL_DIR.iterdir()) if MAIL_DIR.exists() else []
    parts.append(f"📬 Unread mail to human: **{len(unread)}**")

    approvals = scan_pending_approvals()
    if approvals:
        parts.append("\n**Pending approvals:**")
        for s in approvals:
            parts.append(f"• {s}")

    rc, out, err = run_mg(['list', '--json'])
    in_flight = []
    if rc == 0:
        for line in out.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                d = json.loads(line)
                if d.get('status') in ('available', 'claimed', 'pending'):
                    in_flight.append(d)
            except json.JSONDecodeError:
                pass
    elif err:
        parts.append(f"\n(mg list error: {err.strip()[:200]})")

    if in_flight:
        parts.append("\n**In-flight work:**")
        for d in in_flight:
            iid = d.get('id', '?')
            status = d.get('status', '?')
            title = (d.get('title') or '?')[:80]
            assignee = d.get('assignee') or '—'
            parts.append(f"• [{iid}] {status}: {title} (→ {assignee})")
    else:
        parts.append("\n**In-flight work:** (none)")

    return '\n'.join(parts)


def handle_command(text: str) -> str:
    text = text.strip()
    low = text.lower()

    if low.startswith('approve mg-'):
        parts = text.split(None, 1)
        mg_id = parts[1] if len(parts) > 1 else ''
        rc, out, err = run_mg([
            'mail', 'send', 'architect',
            '--from=human',
            f'--subject=approve {mg_id}',
            '--body=approved via discord',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ approve sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('reject mg-'):
        parts = text.split(None, 2)
        if len(parts) < 2:
            return "Usage: `reject mg-XXXX <reason>`"
        mg_id = parts[1]
        reason = parts[2] if len(parts) > 2 else 'rejected via discord'
        rc, out, err = run_mg([
            'mail', 'send', 'architect',
            '--from=human',
            f'--subject=reject {mg_id}',
            f'--body={reason}',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ reject sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('revise mg-'):
        parts = text.split(None, 2)
        if len(parts) < 3:
            return "Usage: `revise mg-XXXX <feedback>`"
        mg_id = parts[1]
        feedback = parts[2]
        sh_rc, sh_out, _ = run_mg(['show', mg_id])
        if sh_rc == 0 and re.search(r'^Status:\s+shelved', sh_out, re.MULTILINE):
            run_mg(['unshelve', mg_id])
        rc, out, err = run_mg([
            'mail', 'send', 'architect',
            '--from=human',
            f'--subject=revise {mg_id}',
            f'--body={feedback}',
        ])
        if rc == 0:
            n = mark_mail_read(mg_id=mg_id)
            tail = f" (cleared {n} related mail{'s' if n != 1 else ''})" if n else ''
            return f"✓ revise sent: `{mg_id}`{tail}"
        return f"✗ failed: {err or out}"

    if low.startswith('read mg-'):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `read mg-XXXX`"
        mg_id = parts[1].strip()
        matches = find_mails_for(mg_id)
        if not matches:
            return f"No mail found for `{mg_id}`."
        p, mail, dir_name = matches[0]
        state = "unread" if dir_name == 'new' else "read"
        rest = len(matches) - 1
        rest_note = f"\n\n_({rest} other mail{'s' if rest != 1 else ''} also reference this id; this is the newest.)_" if rest else ''
        out = (
            f"📧 from `{mail['from']}` _({state})_\n"
            f"**{mail['subject']}**\n\n"
            f"{mail['body']}"
            f"{rest_note}"
        )
        return out

    if low.startswith('dismiss '):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `dismiss mg-XXXX` or `dismiss all`"
        target = parts[1].strip()
        if target.lower() == 'all':
            n = mark_mail_read(all_unread=True)
            return f"✓ marked {n} mail{'s' if n != 1 else ''} read (inbox-zero)"
        if target.lower().startswith('mg-'):
            n = mark_mail_read(mg_id=target)
            return f"✓ marked {n} mail{'s' if n != 1 else ''} read for `{target}`"
        return "Usage: `dismiss mg-XXXX` or `dismiss all`"

    if low.startswith('next mg-'):
        parts = text.split(None, 1)
        if len(parts) < 2:
            return "Usage: `next mg-XXXX`"
        if DESIGNS_DIR is None:
            return (
                "✗ `next` is unavailable: set `POGO_DESIGNS_DIR` in "
                "`~/.pogo/bridget.env` to the directory containing your "
                "`mg-XXXX.md` design docs."
            )
        if INBOX_REPO is None:
            return (
                "✗ `next` is unavailable: set `POGO_INBOX_REPO` in "
                "`~/.pogo/bridget.env` to the repo where new ideas should be filed."
            )
        parent_id = parts[1].strip()
        design_path = DESIGNS_DIR / f"{parent_id}.md"
        if not design_path.exists():
            return f"No design doc found for `{parent_id}`."
        try:
            content = design_path.read_text()
        except Exception as e:
            return f"Failed to read design: {e}"
        rm = re.search(r'^## Roadmap[^\n]*\n(.*?)(?=^## |\Z)', content, re.MULTILINE | re.DOTALL)
        if not rm:
            return f"No Roadmap section in `{parent_id}`'s design."
        roadmap_body = rm.group(1)
        tm = re.search(r'^(### Task \d+[^\n]*)\n(.*?)(?=^### |\Z)', roadmap_body, re.MULTILINE | re.DOTALL)
        if not tm:
            return f"No tasks remaining in `{parent_id}`'s Roadmap."
        heading = tm.group(1).strip()
        body_text = tm.group(2).strip()
        name_match = re.search(r'`([^`]+)`', heading)
        short_name = name_match.group(1) if name_match else heading[:60]
        idea_body = (
            f"From {parent_id}'s Roadmap: {heading}\n\n"
            f"Parent design: {design_path}\n\n"
            f"---\n\n{body_text}"
        )
        rc, out, err = run_mg([
            'new', '--type=idea',
            f'--title=Roadmap: {short_name}',
            f'--body={idea_body}',
            '--assignee=architect',
            '--tag=pogo-inbox',
            f'--repo={INBOX_REPO}',
        ])
        return f"✓ next idea filed:\n```\n{out.strip()}\n```" if rc == 0 else f"✗ failed: {err or out}"

    if low.startswith('explain mg-'):
        parts = text.split(None, 2)
        if len(parts) < 3:
            return "Usage: `explain mg-XXXX <what to explain>`"
        mg_id = parts[1]
        topic = parts[2]
        rc, out, err = run_mg([
            'mail', 'send', 'architect',
            '--from=human',
            f'--subject=explain {mg_id}',
            f'--body={topic}',
        ])
        return f"✓ explain request sent: `{mg_id}`" if rc == 0 else f"✗ failed: {err or out}"

    if low == 'agents' or low == 'agent list' or low == 'crew':
        rc, out, err = run_pogo(['agent', 'list', '--json'])
        if rc != 0:
            return f'✗ pogo agent list failed: {err or out}'
        try:
            agents_list = json.loads(out)
        except json.JSONDecodeError as e:
            return f'✗ failed to parse agent list: {e}'
        if not agents_list:
            return '🤖 No crew agents registered.'
        lines = [f'🤖 **Crew agents ({len(agents_list)}):**']
        for a in agents_list:
            name = a.get('name', '?')
            rc2, dout, _ = run_pogo(['agent', 'diagnose', name, '--json'])
            health = '?'
            if rc2 == 0:
                try:
                    health = json.loads(dout).get('health', '?')
                except json.JSONDecodeError:
                    pass
            status = a.get('status', '?')
            cycle = agent_cycle_paren(name)
            lines.append(f'  • {name:<12} — {status}, {health:<10} {cycle}')
        return '\n'.join(lines)

    if low.startswith('nudge '):
        parts = text.split(None, 2)
        if len(parts) < 2:
            return 'Usage: nudge <agent-name> [reason]'
        agent_name = parts[1]
        reason = parts[2] if len(parts) > 2 else 'status check'
        rc, out, err = run_pogo(['nudge', agent_name, reason])
        if rc == 0:
            return f'✓ nudged {agent_name}: "{reason}"'
        return f'✗ nudge failed: {err or out}'

    if low == 'restart':
        rc, out, err = run_shell(
            ['git', '-C', str(BRIDGET_REPO), 'pull', '--ff-only'], timeout=30,
        )
        if rc != 0:
            return f'❌ git pull failed: {(err or out).strip()[:200]}; staying on old code.'
        rc_sha, sha_out, _ = run_shell(
            ['git', '-C', str(BRIDGET_REPO), 'rev-parse', '--short', 'HEAD'], timeout=10,
        )
        sha = sha_out.strip() if rc_sha == 0 else '?'
        rc_b, _, err_b = run_shell(
            ['bash', 'build.sh'], timeout=10, cwd=str(BRIDGET_REPO),
        )
        if rc_b != 0:
            return f'❌ syntax check failed: {err_b.strip()[:200]}; staying on old code.'
        # 2s gives the Discord ack time to flush before launchd respawns us.
        client.loop.call_later(2.0, lambda: os._exit(0))
        return f'✅ pulled {sha}; restarting in 2s'

    if low == 'mail' or low.startswith('mail '):
        rest = text[len('mail'):].lstrip()
        if '\n' in rest:
            subject, body = rest.split('\n', 1)
            subject = subject.strip()
            body = body.rstrip()
        else:
            subject = rest.strip()
            body = '(no body)'
        if not subject:
            return 'Usage: mail <subject>\n[optional body, multi-line OK]'
        recipient = CONFIG['mail_recipient']
        rc, out, err = run_mg([
            'mail', 'send', recipient,
            '--from=human',
            f'--subject={subject}',
            f'--body={body}',
        ])
        if rc == 0:
            return f'✓ mailed {recipient}: "{subject[:60]}"'
        return f'✗ mail failed: {(err or out).strip()[:200]}'

    if low in ('help', '?', 'commands'):
        return (
            "**Commands:**\n"
            "• `approve mg-XXXX` — approve a design (auto-clears related mails)\n"
            "• `reject mg-XXXX <reason>` — shelve idea + clear mails\n"
            "• `revise mg-XXXX <feedback>` — request changes (auto-unshelves; clears mails)\n"
            "• `explain mg-XXXX <what>` — ask architect to elaborate without redesigning\n"
            "• `next mg-XXXX` — file the next Roadmap task from this design as a new idea\n"
            "• `read mg-XXXX` — print the latest mail referencing this id\n"
            "• `idea: <text>` — file a new idea\n"
            "• `idea: [tag] <text>` — file with extra scope tag (e.g. `[bridget]`)\n"
            "• `bug: <text>` — file a new bug (existing software is broken, not a new feature)\n"
            "• `bug: [tag] <text>` — file a bug with extra scope tag (e.g. `[discord-bridge]`)\n"
            "• `mail <subject>\\n<body>` — send a mail (without a newline, the whole text becomes the subject)\n"
            "• `dismiss mg-XXXX` — mark all unread mail about an mg-id as read\n"
            "• `dismiss all` — inbox-zero everything\n"
            "• `status` — global pull view (unread mail + in-flight work)\n"
            "• `agents` — list crew agents and health\n"
            "• `nudge <agent> [reason]` — wake a stalled agent\n"
            "• `restart` — git pull + restart bridget (after merging a PR)\n"
            "• `quiet <true|false> [HH:MM HH:MM]` — toggle agent quiet hours (default 23:00–06:00)\n"
            "• `help` (or `?`) — this list"
        )

    if low.startswith('idea:'):
        body = text[5:].strip()
        if not body:
            return "Usage: `idea: [optional-tag] <description>`"
        if INBOX_REPO is None:
            return (
                "✗ `idea:` is unavailable: set `POGO_INBOX_REPO` in "
                "`~/.pogo/bridget.env` to the repo where new ideas should be filed."
            )
        extra_tags = []
        m = re.match(r'^\[([^\]]+)\]\s*(.*)$', body, re.DOTALL)
        if m:
            extra_tags.append(m.group(1).strip())
            body = m.group(2).strip()
        if not body:
            return "Usage: `idea: [optional-tag] <description>`"
        title = body.splitlines()[0][:60]
        args = [
            'new', '--type=idea',
            f'--title={title}',
            f'--body={body}',
            '--assignee=architect',
            '--tag=pogo-inbox',
            f'--repo={INBOX_REPO}',
        ]
        for t in extra_tags:
            args.append(f'--tag={t}')
        rc, out, err = run_mg(args)
        return f"✓ idea filed:\n```\n{out.strip()}\n```" if rc == 0 else f"✗ failed: {err or out}"

    if low.startswith('bug:'):
        body = text[4:].strip()
        if not body:
            return "Usage: `bug: [optional-tag] <description>`"
        if INBOX_REPO is None:
            return (
                "✗ `bug:` is unavailable: set `POGO_INBOX_REPO` in "
                "`~/.pogo/bridget.env` to the repo where new bugs should be filed."
            )
        extra_tags = []
        m = re.match(r'^\[([^\]]+)\]\s*(.*)$', body, re.DOTALL)
        if m:
            extra_tags.append(m.group(1).strip())
            body = m.group(2).strip()
        if not body:
            return "Usage: `bug: [optional-tag] <description>`"
        title = body.splitlines()[0][:60]
        args = [
            'new', '--type=bug',
            f'--title={title}',
            f'--body={body}',
            '--assignee=architect',
            '--tag=pogo-inbox',
            f'--repo={INBOX_REPO}',
        ]
        for t in extra_tags:
            args.append(f'--tag={t}')
        rc, out, err = run_mg(args)
        return f"✓ bug filed:\n```\n{out.strip()}\n```" if rc == 0 else f"✗ failed: {err or out}"

    if low == 'quiet' or low.startswith('quiet '):
        rest = text.split()[1:]
        if not rest or (len(rest) == 1 and rest[0].lower() == 'status'):
            state = load_quiet()
            if state['enabled']:
                return f"🌙 quiet hours: enabled, {state['start']}–{state['end']} (local)."
            return f"quiet hours: disabled. (window {state['start']}–{state['end']})"
        if len(rest) == 2 and TIME_RE.match(rest[0]) and TIME_RE.match(rest[1]):
            return "Usage: `quiet <true|false> [HH:MM HH:MM]`"
        flag = rest[0].lower()
        if flag not in ('true', 'false'):
            return "Usage: `quiet <true|false> [HH:MM HH:MM]`"
        state = load_quiet()
        times = rest[1:]
        if times:
            if len(times) != 2 or not TIME_RE.match(times[0]) or not TIME_RE.match(times[1]):
                return "Usage: `quiet <true|false> [HH:MM HH:MM]` (times must match HH:MM)"
            state['start'] = times[0]
            state['end'] = times[1]
        if flag == 'true':
            state['enabled'] = True
            save_quiet(state)
            return f"✓ quiet hours: enabled, {state['start']}–{state['end']} (local)."
        state['enabled'] = False
        save_quiet(state)
        return f"✓ quiet hours: disabled. (window {state['start']}–{state['end']} preserved for next enable)"

    if low == 'status' or low.startswith('status'):
        summary = get_status_summary()
        if len(summary) > STATUS_OUTPUT_BUDGET:
            summary = summary[:STATUS_OUTPUT_BUDGET] + '\n…(truncated)'
        return summary

    return (
        "Unrecognized. Send `help` for the full command list."
    )


@client.event
async def on_ready():
    print(f"logged in as {client.user} (id={client.user.id})", flush=True)
    try:
        user = await client.fetch_user(USER_ID)
    except discord.NotFound:
        print(f"user {USER_ID} not found", file=sys.stderr)
        await client.close()
        return
    client.loop.create_task(watch_mailbox(user))
    client.loop.create_task(watch_task_transitions(user))
    client.loop.create_task(watch_idea_claims(user))


@client.event
async def on_message(message: discord.Message):
    if message.author.bot:
        return
    if message.author.id != USER_ID:
        return
    if not isinstance(message.channel, discord.DMChannel):
        return
    reply = handle_command(message.content)
    if len(reply) > DISCORD_MSG_LIMIT:
        reply = reply[:DISCORD_MSG_LIMIT] + '…'
    try:
        await message.channel.send(reply)
    except discord.HTTPException as e:
        print(f"reply send failed: {e}", file=sys.stderr)


