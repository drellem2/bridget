# bridget configuration. Copy this to ~/.pogo/bridget.env and fill in values.
# Format: key=value (one per line, no quotes, no leading/trailing whitespace
# around the `=`). Lines starting with `#` and blank lines are ignored.
#
# Process environment variables with the same names override values here, so
# launchd / systemd unit files can inject overrides without editing this file.

# ─── Required ─────────────────────────────────────────────────────────────────

# Discord bot token. Create a bot at https://discord.com/developers/applications,
# enable the "Message Content" privileged intent, and paste the token here.
DISCORD_BOT_TOKEN=

# Your Discord user ID (snowflake — an integer, e.g. 123456789012345678).
# Enable Developer Mode in Discord, right-click your name → Copy User ID.
# bridget will only respond to DMs from this user.
DISCORD_USER_ID=

# The Discord server (guild) the bot is installed in. Right-click the server
# icon in Developer Mode → Copy Server ID.
DISCORD_SERVER_ID=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Absolute path to the `mg` binary. If unset, bridget resolves it via PATH
# (`shutil.which("mg")`). Set this only if `mg` is installed somewhere your
# shell PATH doesn't reach when bridget runs (e.g. under launchd).
#MG_BIN=/usr/local/bin/mg

# Absolute path to the `pogo` binary. If unset, bridget resolves it via PATH
# (`shutil.which("pogo")`). Set this only if `pogo` is installed somewhere your
# shell PATH doesn't reach when bridget runs (e.g. under launchd).
#POGO_BIN=/usr/local/bin/pogo

# Parent directory of `new/` and `cur/` mail subdirs. Default:
# ~/.macguffin/mail/human (the canonical pogo mail location). Override if your
# pogo install puts mail elsewhere.
#POGO_MAIL_DIR=~/.macguffin/mail/human

# Directory containing `mg-XXXX.md` design docs, used by the `next mg-XXXX`
# command. Default: ~/.pogo/designs (auto-created by your design-writing
# workflow if you use one). Set this only if your design docs live elsewhere.
#POGO_DESIGNS_DIR=~/Pogo/designs

# Repo (or directory used as one) where new items filed via `idea:`, `bug:`,
# and `next` should be created. Default: ~/.pogo/inbox. Set this only if you
# want new items routed to a specific tracked repo.
#POGO_INBOX_REPO=~/Pogo

# Default recipient agent for the `mail <subject>` Discord command. Default:
# `mayor`. Override if your install routes mail to a differently-named
# coordinator agent.
#POGO_MAIL_RECIPIENT=mayor

# Optional override for the bridget git checkout directory. By default,
# bridget self-detects this from its own script location (works when
# ~/.pogo/bin/bridget is symlinked into the repo, which is what install.sh
# does). Set this only if you run bridget from an unusual setup.
#BRIDGET_REPO_DIR=/Users/yourname/DUGLocal/bridget

# ─── Behavioural knobs (defaults preserve v1.0.0 behavior) ────────────────────

# Recipient/assignee for the workflow verbs (approve / reject / revise /
# explain / next mg-XXXX) and filing commands (idea: / bug:). Default:
# `architect`. Override if your install routes design coordination through a
# different agent (e.g. a per-PM agent or a coordinator).
#POGO_WORKFLOW_AGENT=architect

# Base tag stamped on items filed via `idea:`, `bug:`, and `next`. Inline
# `[scope]` tags from the user are still appended on top. Default:
# `pogo-inbox`. Override if your install uses a different inbox-tag
# convention.
#POGO_INBOX_TAG=pogo-inbox

# Polling interval in seconds for the mailbox / task-transitions / idea-claims
# watchers. Default: `5`. Lower = snappier notifications + more `mg list`
# work; higher = quieter on flaky networks or shared dev hosts.
#BRIDGET_POLL_INTERVAL=5

# When `true`, the outbound watchers consult ~/.pogo/quiet.json and suppress
# DMs while quiet hours are active (state still updates internally — only the
# user-facing send is gated). Inbound DMs from the user are always processed,
# since typing during quiet hours is consenting. Default: `false` (no change
# from v1.0.0). Most Daniel-shaped installs probably want `true`.
#BRIDGET_QUIET_RESPECTS_OUTBOUND=false

# Regex matched against the first `Subject:` header of an unread mail to flag
# it as an approval request in `status`. Default: `^Subject: approval needed `
# (literal v1.0.0 prefix). Override if your pogo install uses a different
# approval-mail subject convention.
#BRIDGET_APPROVAL_RE=^Subject: approval needed

# Shell command to validate the new bridget checkout before respawning, run
# from BRIDGET_REPO_DIR. Default: `bash build.sh`. Override on hosts without
# bash, or if you've renamed the build script (e.g. `make check`).
#BRIDGET_RESTART_CMD=bash build.sh

# Regex matched against `assignee` to decide whether `claimed by …`
# annotation should be added to a task-transition message. Anything that
# matches the pattern is treated as a *crew agent* (annotation suppressed);
# anything that does not match is a polecat (`by polecat-foo` is appended).
# Default: `^(architect|mayor|human|pm-.*|)$` — widens the v1.0.0 literal
# `{architect, mayor, human, ''}` set to also absorb any `pm-*` agent.
# Override if your install names crew agents differently
# (e.g. `^(coordinator-.*|lead-.*|architect|)$`).
#BRIDGET_CREW_PATTERN=^(architect|mayor|human|pm-.*|)$
